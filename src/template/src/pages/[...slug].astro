---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import DocsLayout from '../layouts/DocsLayout.astro';
import APILayout from '../layouts/APILayout.astro';
import * as mdxComponents from '../components/mdx';
import i18n from 'virtual:docsy/i18n';
import { detectLangFromPath } from '../utils/i18n-helpers';

type DocsEntry = CollectionEntry<'docs'>;

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((entry: DocsEntry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: DocsEntry };
const { Content, headings } = await render(entry);

const frontmatter = entry.data;
const isApiPage = !!(frontmatter.api || frontmatter.openapi);
const currentLang = detectLangFromPath(Astro.url.pathname, i18n);
---

{isApiPage ? (
  <APILayout
    title={frontmatter.title}
    description={frontmatter.description}
    noindex={frontmatter.noindex}
    api={frontmatter.api}
    openapi={frontmatter.openapi}
    lang={currentLang}
    ogTitle={frontmatter['og:title']}
    ogDescription={frontmatter['og:description']}
    ogImage={frontmatter['og:image']}
    twitterTitle={frontmatter['twitter:title']}
    twitterDescription={frontmatter['twitter:description']}
    twitterImage={frontmatter['twitter:image']}
  >
    <Content components={mdxComponents} />
  </APILayout>
) : (
  <DocsLayout
    title={frontmatter.title}
    description={frontmatter.description}
    headings={headings}
    noindex={frontmatter.noindex}
    mode={frontmatter.mode}
    lang={currentLang}
    ogTitle={frontmatter['og:title']}
    ogDescription={frontmatter['og:description']}
    ogImage={frontmatter['og:image']}
    twitterTitle={frontmatter['twitter:title']}
    twitterDescription={frontmatter['twitter:description']}
    twitterImage={frontmatter['twitter:image']}
  >
    <Content components={mdxComponents} />
  </DocsLayout>
)}
