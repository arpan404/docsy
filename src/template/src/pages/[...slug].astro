---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../layouts/DocsLayout.astro';
import APILayout from '../layouts/APILayout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const frontmatter = entry.data;
const isApiPage = !!(frontmatter.api || frontmatter.openapi);
---

{isApiPage ? (
  <APILayout
    title={frontmatter.title}
    description={frontmatter.description}
    noindex={frontmatter.noindex}
    api={frontmatter.api}
    openapi={frontmatter.openapi}
    ogTitle={frontmatter['og:title']}
    ogDescription={frontmatter['og:description']}
    ogImage={frontmatter['og:image']}
    twitterTitle={frontmatter['twitter:title']}
    twitterDescription={frontmatter['twitter:description']}
    twitterImage={frontmatter['twitter:image']}
  >
    <Content />
  </APILayout>
) : (
  <DocsLayout
    title={frontmatter.title}
    description={frontmatter.description}
    headings={headings}
    noindex={frontmatter.noindex}
    mode={frontmatter.mode}
    ogTitle={frontmatter['og:title']}
    ogDescription={frontmatter['og:description']}
    ogImage={frontmatter['og:image']}
    twitterTitle={frontmatter['twitter:title']}
    twitterDescription={frontmatter['twitter:description']}
    twitterImage={frontmatter['twitter:image']}
  >
    <Content />
  </DocsLayout>
)}
