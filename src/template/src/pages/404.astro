---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <main class="not-found">
    <div class="not-found-inner">
      <p class="not-found-code">404</p>
      <h1 class="not-found-title">Page not found</h1>
      <p class="not-found-message">
        The page you are looking for does not exist or has been moved.
      </p>
      <a href="/" class="not-found-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 4L6 8l4 4" />
        </svg>
        Back to home
      </a>
    </div>
  </main>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - var(--docsy-topnav-height, 64px));
    padding: 2rem;
    text-align: center;
  }

  .not-found-inner {
    max-width: 420px;
  }

  .not-found-code {
    font-size: 4rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--docsy-text-muted, #9ca3af);
    margin: 0 0 0.5rem 0;
    line-height: 1;
  }

  .not-found-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--docsy-text-primary, #111827);
    margin: 0 0 0.75rem 0;
  }

  .not-found-message {
    font-size: 1rem;
    color: var(--docsy-text-secondary, #6b7280);
    line-height: 1.6;
    margin: 0 0 1.5rem 0;
  }

  .not-found-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--docsy-color-primary, #6366f1);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .not-found-link:hover {
    opacity: 0.8;
  }
</style>
