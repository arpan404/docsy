---
import BaseLayout from './BaseLayout.astro';
import config from 'virtual:docsy/config';
import Sidebar from '../components/nav/Sidebar.astro';
import Breadcrumbs from '../components/nav/Breadcrumbs.astro';
import Footer from '../components/nav/Footer.astro';
import APIPlayground from '../components/api-playground/APIPlayground.astro';
import navigation from 'virtual:docsy/navigation';
import i18n from 'virtual:docsy/i18n';
import openapiData from 'virtual:docsy/openapi';
import { detectLangFromPath } from '../utils/i18n-helpers';

interface PaginationItem {
  slug: string;
  title: string;
}

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  api?: string;
  openapi?: string;
  lang?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
}

const {
  title,
  description,
  noindex,
  api,
  openapi,
  lang,
  ogTitle,
  ogDescription,
  ogImage,
  twitterTitle,
  twitterDescription,
  twitterImage,
} = Astro.props;

// Compute previous/next page links
const currentSlug = Astro.url.pathname.replace(/^\//, '').replace(/\/$/, '');
const currentLang = lang || detectLangFromPath(Astro.url.pathname, i18n);
const langNav = i18n.navigation[currentLang] || navigation;
const flatItems = langNav.flatItems || navigation.flatItems || [];
const currentIndex = flatItems.findIndex(
  (item: PaginationItem & { order: number; group: string }) => item.slug === currentSlug
);
const prev: PaginationItem | undefined = currentIndex > 0 ? flatItems[currentIndex - 1] : undefined;
const next: PaginationItem | undefined =
  currentIndex >= 0 && currentIndex < flatItems.length - 1
    ? flatItems[currentIndex + 1]
    : undefined;

// Derive HTTP method and endpoint from the api string (e.g. "GET /v1/users")
let method = '';
let endpoint = '';
let resolvedOpenApiEndpoint: (typeof openapiData.endpoints)[number] | undefined;
if (api) {
  const parts = api.split(/\s+/);
  if (parts.length >= 2) {
    method = parts[0].toUpperCase();
    endpoint = parts.slice(1).join(' ');
  } else {
    endpoint = api;
  }
} else if (openapi) {
  const openapiKey = String(openapi).trim();
  const fromOperationId = openapiData.endpointsByOperationId?.[openapiKey];
  const methodPathKey = toMethodPathKey(openapiKey);
  const fromMethodPath = methodPathKey ? openapiData.endpointsByMethodPath?.[methodPathKey] : undefined;
  const fromPath = openapiData.endpointsByPath?.[openapiKey]?.[0];
  const resolvedEndpoint = fromOperationId || fromMethodPath || fromPath;
  resolvedOpenApiEndpoint = resolvedEndpoint;

  if (resolvedEndpoint) {
    method = resolvedEndpoint.method.toUpperCase();
    endpoint = resolvedEndpoint.path;
  }
}

const configuredBaseUrls = Array.isArray(config.api?.baseUrl)
  ? config.api?.baseUrl
  : config.api?.baseUrl
    ? [config.api.baseUrl]
    : [];
const apiBaseUrl = configuredBaseUrls[0] || openapiData.baseUrls?.[0] || '';
const apiProxyEnabled = !!config.api?.playground?.proxy;
const playgroundDisplay = config.api?.playground?.display || 'interactive';
const apiExampleLanguages = config.api?.examples?.languages || ['curl', 'python', 'javascript'];

const methodColors: Record<string, string> = {
  GET: '#22c55e',
  POST: '#3b82f6',
  PUT: '#f59e0b',
  PATCH: '#f59e0b',
  DELETE: '#ef4444',
};
const methodColor = methodColors[method] || 'var(--docsy-color-primary, #6366f1)';

const defaultPathParams: Record<string, string> = {};
const defaultQueryParams: Array<{ key: string; value: string }> = [];
const defaultHeaders: Array<{ key: string; value: string }> = [];
let defaultBody = '';
let hideEmptyQueryRow = false;

if (resolvedOpenApiEndpoint) {
  for (const parameter of resolvedOpenApiEndpoint.parameters || []) {
    const rawExample = parameter.example ?? parameter.schema?.example ?? parameter.schema?.default;
    const value = rawExample == null ? '' : String(rawExample);

    if (parameter.in === 'path') {
      defaultPathParams[parameter.name] = value;
    } else if (parameter.in === 'query') {
      defaultQueryParams.push({ key: parameter.name, value });
    } else if (parameter.in === 'header') {
      defaultHeaders.push({ key: parameter.name, value });
    }
  }

  const requestBody = resolvedOpenApiEndpoint.requestBody;
  if (requestBody?.contentType && !defaultHeaders.some((header) => header.key.toLowerCase() === 'content-type')) {
    defaultHeaders.push({ key: 'Content-Type', value: requestBody.contentType });
  }

  if (requestBody?.schema) {
    const bodyExample = requestBody.schema.example ?? requestBody.schema.default ?? buildSchemaExample(requestBody.schema);
    if (bodyExample !== undefined) {
      defaultBody = typeof bodyExample === 'string'
        ? bodyExample
        : JSON.stringify(bodyExample, null, 2);
    }
  }

  hideEmptyQueryRow = defaultQueryParams.length === 0;
}

function toMethodPathKey(value: string): string | null {
  const parts = value.trim().split(/\s+/);
  if (parts.length < 2) return null;

  const candidateMethod = parts[0].toUpperCase();
  if (!['GET', 'POST', 'PUT', 'PATCH', 'DELETE'].includes(candidateMethod)) {
    return null;
  }

  return `${candidateMethod} ${parts.slice(1).join(' ')}`;
}

function buildSchemaExample(schema: any): any {
  if (!schema || typeof schema !== 'object') return undefined;

  if (schema.example !== undefined) return schema.example;
  if (schema.default !== undefined) return schema.default;

  if (schema.type === 'object' || schema.properties) {
    const result: Record<string, any> = {};
    const properties = schema.properties || {};
    for (const [key, propertySchema] of Object.entries(properties)) {
      const value = buildSchemaExample(propertySchema);
      if (value !== undefined) {
        result[key] = value;
      }
    }
    return Object.keys(result).length > 0 ? result : {};
  }

  if (schema.type === 'array') {
    const itemExample = buildSchemaExample(schema.items);
    return itemExample !== undefined ? [itemExample] : [];
  }

  if (Array.isArray(schema.enum) && schema.enum.length > 0) {
    return schema.enum[0];
  }

  switch (schema.type) {
    case 'string':
      return '';
    case 'integer':
    case 'number':
      return 0;
    case 'boolean':
      return false;
    default:
      return undefined;
  }
}
---

<BaseLayout
  title={title}
  description={description}
  noindex={noindex}
  lang={currentLang}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  twitterTitle={twitterTitle}
  twitterDescription={twitterDescription}
  twitterImage={twitterImage}
>
  <div class="api-layout">
    <Sidebar />

    <div class="api-main">
      <div class="api-columns">
        <!-- Left column: description content -->
        <main class="api-description" id="main-content">
          <article class="api-article">
            <Breadcrumbs />

            {title && (
              <header class="api-header">
                {method && (
                  <div class="api-endpoint">
                    <span class="api-method" style={`background: ${methodColor};`}>
                      {method}
                    </span>
                    <code class="api-path">{endpoint}</code>
                  </div>
                )}
                <h1 class="api-title">{title}</h1>
                {description && <p class="api-description-text">{description}</p>}
              </header>
            )}

            <div class="api-content prose">
              <slot />
            </div>
          </article>
        </main>

        <!-- Right column: playground / code examples -->
        <aside class="api-playground-column">
          <div class="api-playground-sticky">
            <slot name="playground">
              {/* Render the interactive API Playground when api metadata is available */}
              {playgroundDisplay === 'interactive' && (api || openapi) && method && endpoint ? (
                <APIPlayground
                  method={method}
                  endpoint={endpoint}
                  baseUrl={apiBaseUrl}
                  defaultPathParams={defaultPathParams}
                  defaultQueryParams={defaultQueryParams}
                  defaultHeaders={defaultHeaders}
                  defaultBody={defaultBody}
                  hideEmptyQueryRow={hideEmptyQueryRow}
                  proxy={apiProxyEnabled}
                  exampleLanguages={apiExampleLanguages}
                />
              ) : playgroundDisplay !== 'none' && (api || openapi) ? (
                <div class="api-playground-placeholder">
                  <p class="api-playground-placeholder-text">API Playground</p>
                  {method && endpoint && (
                    <div class="api-playground-preview">
                      <span class="api-method-sm" style={`color: ${methodColor};`}>{method}</span>
                      <code class="api-path-sm">{endpoint}</code>
                    </div>
                  )}
                </div>
              ) : null}
            </slot>
          </div>
        </aside>
      </div>

      <Footer prev={prev} next={next} />
    </div>
  </div>
</BaseLayout>

<style>
  .api-layout {
    display: grid;
    grid-template-columns: var(--docsy-sidebar-width, 260px) minmax(0, 1fr);
    max-width: var(--docsy-max-width, 1440px);
    margin: 0 auto;
  }

  .api-main {
    min-width: 0;
    min-height: calc(100vh - var(--docsy-topnav-height, 64px));
    display: flex;
    flex-direction: column;
  }

  .api-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    flex: 1;
  }

  .api-description {
    min-width: 0;
    border-right: 1px solid var(--docsy-border-color, #e5e7eb);
  }

  .api-article {
    padding: 2rem 1.5rem;
    max-width: 640px;
  }

  .api-header {
    margin-bottom: 2rem;
  }

  .api-endpoint {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .api-method {
    display: inline-flex;
    align-items: center;
    padding: 0.1875rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #ffffff;
    border-radius: 4px;
    font-family: var(--docsy-font-code, monospace);
  }

  .api-path {
    font-size: 0.8125rem;
    font-family: var(--docsy-font-code, monospace);
    color: var(--docsy-text-secondary, #6b7280);
    word-break: break-all;
  }

  .api-title {
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--docsy-text-primary, #111827);
    margin: 0 0 0.5rem 0;
  }

  .api-description-text {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--docsy-text-secondary, #6b7280);
    margin: 0;
  }

  .api-content {
    flex: 1;
  }

  /* Playground column */
  .api-playground-column {
    min-width: 0;
    background: var(--docsy-bg-secondary, #f9fafb);
  }

  .api-playground-sticky {
    position: sticky;
    top: var(--docsy-topnav-height, 64px);
    padding: 2rem 1.5rem;
    max-height: calc(100vh - var(--docsy-topnav-height, 64px));
    overflow-y: auto;
  }

  .api-playground-placeholder {
    padding: 1.5rem;
    border: 1px dashed var(--docsy-border-color, #e5e7eb);
    border-radius: var(--docsy-radius-md, 8px);
    text-align: center;
  }

  .api-playground-placeholder-text {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--docsy-text-muted, #9ca3af);
    margin: 0 0 0.75rem 0;
  }

  .api-playground-preview {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .api-method-sm {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    font-family: var(--docsy-font-code, monospace);
  }

  .api-path-sm {
    font-size: 0.75rem;
    font-family: var(--docsy-font-code, monospace);
    color: var(--docsy-text-secondary, #6b7280);
  }

  /* Responsive: collapse to single column */
  @media (max-width: 1280px) {
    .api-columns {
      grid-template-columns: 1fr;
    }

    .api-description {
      border-right: none;
    }

    .api-playground-column {
      border-top: 1px solid var(--docsy-border-color, #e5e7eb);
    }

    .api-playground-sticky {
      position: static;
      max-height: none;
    }
  }

  /* Responsive: hide sidebar */
  @media (max-width: 1024px) {
    .api-layout {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (max-width: 640px) {
    .api-article {
      padding: 1.5rem 1rem;
    }

    .api-title {
      font-size: 1.375rem;
    }

    .api-playground-sticky {
      padding: 1.5rem 1rem;
    }
  }
</style>
