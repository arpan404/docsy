---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/nav/Sidebar.astro';
import TableOfContents from '../components/nav/TableOfContents.astro';
import Breadcrumbs from '../components/nav/Breadcrumbs.astro';
import Footer from '../components/nav/Footer.astro';
import navigation from 'virtual:docsy/navigation';
import i18n from 'virtual:docsy/i18n';
import { detectLangFromPath } from '../utils/i18n-helpers';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface PaginationItem {
  slug: string;
  title: string;
}

interface Props {
  title?: string;
  description?: string;
  headings?: Heading[];
  noindex?: boolean;
  mode?: 'default' | 'wide' | 'custom';
  lang?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
}

const {
  title,
  description,
  headings = [],
  noindex,
  mode = 'default',
  lang,
  ogTitle,
  ogDescription,
  ogImage,
  twitterTitle,
  twitterDescription,
  twitterImage,
} = Astro.props;

// Compute previous/next page links from the flat navigation list
const currentSlug = Astro.url.pathname.replace(/^\//, '').replace(/\/$/, '');
const currentLang = lang || detectLangFromPath(Astro.url.pathname, i18n);
const langNav = i18n.navigation[currentLang] || navigation;
const flatItems = langNav.flatItems || navigation.flatItems || [];
const currentIndex = flatItems.findIndex(
  (item: PaginationItem & { order: number; group: string }) => item.slug === currentSlug
);
const prev: PaginationItem | undefined = currentIndex > 0 ? flatItems[currentIndex - 1] : undefined;
const next: PaginationItem | undefined =
  currentIndex >= 0 && currentIndex < flatItems.length - 1
    ? flatItems[currentIndex + 1]
    : undefined;

const isWide = mode === 'wide';
---

<BaseLayout
  title={title}
  description={description}
  noindex={noindex}
  lang={currentLang}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  twitterTitle={twitterTitle}
  twitterDescription={twitterDescription}
  twitterImage={twitterImage}
>
  <div class:list={['docs-layout', { 'docs-layout--wide': isWide }]}>
    <Sidebar />

    <main class="docs-main" id="main-content">
      <article class="docs-article">
        <Breadcrumbs />

        {title && (
          <header class="docs-header">
            <h1 class="docs-title">{title}</h1>
            {description && <p class="docs-description">{description}</p>}
          </header>
        )}

        <div class="docs-content prose">
          <slot />
        </div>
      </article>

      <Footer prev={prev} next={next} />
    </main>

    {!isWide && headings.length > 0 && (
      <TableOfContents headings={headings} />
    )}
  </div>
</BaseLayout>

<style>
  .docs-layout {
    display: grid;
    grid-template-columns: var(--docsy-sidebar-width, 260px) minmax(0, 1fr) var(--docsy-toc-width, 220px);
    max-width: var(--docsy-max-width, 1440px);
    margin: 0 auto;
  }

  .docs-layout--wide {
    grid-template-columns: var(--docsy-sidebar-width, 260px) minmax(0, 1fr);
  }

  .docs-main {
    min-width: 0;
    min-height: calc(100vh - var(--docsy-topnav-height, 64px));
    display: flex;
    flex-direction: column;
  }

  .docs-article {
    flex: 1;
    width: 100%;
    max-width: var(--docsy-content-width, 768px);
    margin: 0 auto;
    padding: var(--docsy-content-padding-y, 2rem) var(--docsy-content-padding-x, 1.5rem);
  }

  .docs-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: var(--docsy-border, 1px solid #e5e7eb);
  }

  .docs-title {
    font-size: var(--docsy-heading-h1-size, 2rem);
    font-weight: var(--docsy-heading-weight, 700);
    line-height: var(--docsy-heading-line-height, 1.25);
    letter-spacing: var(--docsy-letter-spacing-tight, -0.025em);
    font-family: var(--docsy-font-headings, inherit);
    color: var(--docsy-text-primary, #111827);
    margin: 0 0 0.5rem 0;
  }

  .docs-description {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--docsy-text-secondary, #6b7280);
    margin: 0;
  }

  .docs-content {
    flex: 1;
  }

  /* Responsive: hide TOC */
  @media (max-width: 1280px) {
    .docs-layout {
      grid-template-columns: var(--docsy-sidebar-width, 260px) minmax(0, 1fr);
    }
  }

  /* Responsive: hide sidebar */
  @media (max-width: 1024px) {
    .docs-layout,
    .docs-layout--wide {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (max-width: 640px) {
    .docs-article {
      padding: var(--docsy-content-padding-y, 1.5rem) var(--docsy-content-padding-x, 1rem);
    }

    .docs-title {
      font-size: 1.5rem;
    }
  }
</style>

<style is:global>
  /* === Prose styles for rendered Markdown/MDX content === */
  .prose {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--docsy-text-primary, #111827);
  }

  .prose > * + * {
    margin-top: 1.25em;
  }

  .prose h1,
  .prose h2,
  .prose h3,
  .prose h4,
  .prose h5,
  .prose h6 {
    font-weight: var(--docsy-heading-weight, 700);
    line-height: var(--docsy-heading-line-height, 1.25);
    letter-spacing: -0.01em;
    color: var(--docsy-text-primary, #111827);
    font-family: var(--docsy-font-headings, inherit);
    scroll-margin-top: calc(var(--docsy-topnav-height, 64px) + 1rem);
  }

  .prose h1 { font-size: var(--docsy-heading-h1-size, 2.25rem); margin-top: 0; margin-bottom: 0.75em; font-weight: var(--docsy-heading-weight, 700); }
  .prose h2 { font-size: var(--docsy-heading-h2-size, 1.5rem); margin-top: 2em; margin-bottom: 0.5em; padding-bottom: 0.25em; border-bottom: var(--docsy-border, 1px solid #e5e7eb); }
  .prose h3 { font-size: var(--docsy-heading-h3-size, 1.25rem); margin-top: 1.75em; margin-bottom: 0.5em; }
  .prose h4 { font-size: var(--docsy-heading-h4-size, 1.125rem); margin-top: 1.5em; margin-bottom: 0.5em; }

  .prose p {
    margin-top: 1.25em;
    margin-bottom: 1.25em;
  }

  .prose a {
    color: var(--docsy-color-primary, #6366f1);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: var(--docsy-color-primary, #6366f1);
    opacity: 1;
    transition: opacity var(--docsy-transition-normal, 0.15s ease);
  }

  .prose a:hover {
    opacity: 0.8;
  }

  .prose strong {
    font-weight: 600;
    color: var(--docsy-text-primary, #111827);
  }

  .prose ul,
  .prose ol {
    padding-left: 1.5em;
    margin-top: 1.25em;
    margin-bottom: 1.25em;
  }

  .prose li {
    margin-top: 0.375em;
    margin-bottom: 0.375em;
  }

  .prose li > ul,
  .prose li > ol {
    margin-top: 0.25em;
    margin-bottom: 0.25em;
  }

  .prose code {
    font-family: var(--docsy-font-code, 'SF Mono', Monaco, 'Cascadia Code', 'Roboto Mono', Menlo, monospace);
    font-size: 0.875em;
    font-weight: 500;
    color: var(--docsy-text-primary, #111827);
    background: var(--docsy-bg-secondary, #f3f4f6);
    padding: 0.125em 0.375em;
    border-radius: var(--docsy-radius-sm, 6px);
  }

  .prose pre {
    font-family: var(--docsy-font-code, 'SF Mono', Monaco, 'Cascadia Code', 'Roboto Mono', Menlo, monospace);
    font-size: var(--docsy-code-font-size, 0.8125rem);
    line-height: 1.7;
    overflow-x: auto;
    padding: var(--docsy-code-padding, 1rem 1.25rem);
    border-radius: var(--docsy-radius-md, 8px);
    border: var(--docsy-border, 1px solid #e5e7eb);
    margin-top: 1.5em;
    margin-bottom: 1.5em;
  }

  .prose pre code {
    background: none;
    padding: 0;
    font-size: inherit;
    font-weight: 400;
    color: inherit;
    border-radius: 0;
  }

  .prose blockquote {
    border-left: var(--docsy-callout-border-width, 4px) solid var(--docsy-color-primary, #6366f1);
    padding: 0.5em 1em;
    margin: 1.5em 0;
    color: var(--docsy-text-secondary, #6b7280);
    font-style: italic;
  }

  .prose blockquote p:first-child {
    margin-top: 0;
  }

  .prose blockquote p:last-child {
    margin-bottom: 0;
  }

  .prose hr {
    border: none;
    border-top: var(--docsy-border, 1px solid #e5e7eb);
    margin: 2em 0;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
    font-size: 0.875rem;
  }

  .prose th {
    font-weight: 600;
    text-align: left;
    padding: 0.625rem 0.75rem;
    border-bottom: 2px solid var(--docsy-border-color, #e5e7eb);
    color: var(--docsy-text-primary, #111827);
  }

  .prose td {
    padding: 0.625rem 0.75rem;
    border-bottom: 1px solid var(--docsy-border-color, #e5e7eb);
  }

  .prose img {
    border-radius: var(--docsy-radius-md, 8px);
    margin: 1.5em 0;
  }
</style>
