---
import config from 'virtual:docsy/config';
import i18n from 'virtual:docsy/i18n';
import { detectLangFromPath, getStrings } from '../../utils/i18n-helpers';

interface PaginationItem {
  slug: string;
  title: string;
}

interface Props {
  prev?: PaginationItem;
  next?: PaginationItem;
}

const { prev, next } = Astro.props;
const currentLang = detectLangFromPath(Astro.url.pathname, i18n);
const strings = getStrings(currentLang, i18n);

const footer = config.footer;
const socials = footer?.socials || config.footerSocials || {};
const columns = footer?.columns || [];

