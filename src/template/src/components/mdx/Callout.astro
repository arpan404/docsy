---
export interface Props {
  type?: 'note' | 'warning' | 'info' | 'tip' | 'check' | 'danger';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const config: Record<string, { icon: string; label: string }> = {
  note: { icon: '\u{1F4DD}', label: 'Note' },
  info: { icon: '\u{2139}\u{FE0F}', label: 'Info' },
  tip: { icon: '\u{1F4A1}', label: 'Tip' },
  check: { icon: '\u{2705}', label: 'Check' },
  warning: { icon: '\u{26A0}\u{FE0F}', label: 'Warning' },
  danger: { icon: '\u{1F6A8}', label: 'Danger' },
};

const c = config[type] || config.note;
const displayTitle = title || c.label;
---

<div class:list={['docsy-callout', `docsy-callout--${type}`]} role="alert">
  <div class="docsy-callout__header">
    <span class="docsy-callout__icon" aria-hidden="true">{c.icon}</span>
    <span class="docsy-callout__title">{displayTitle}</span>
  </div>
  <div class="docsy-callout__body">
    <slot />
  </div>
</div>

<style>
  .docsy-callout {
    margin: 1.5rem 0;
    border-radius: var(--docsy-radius, 0.5rem);
    border-left: 4px solid;
    padding: 0.875rem 1rem;
  }

  .docsy-callout--note {
    border-color: var(--docsy-color-note, #6366f1);
    background: var(--docsy-color-note-bg, #eef2ff);
  }

  .docsy-callout--info {
    border-color: var(--docsy-color-info, #3b82f6);
    background: var(--docsy-color-info-bg, #eff6ff);
  }

  .docsy-callout--tip {
    border-color: var(--docsy-color-tip, #10b981);
    background: var(--docsy-color-tip-bg, #ecfdf5);
  }

  .docsy-callout--check {
    border-color: var(--docsy-color-check, #22c55e);
    background: var(--docsy-color-check-bg, #f0fdf4);
  }

  .docsy-callout--warning {
    border-color: var(--docsy-color-warning, #f59e0b);
    background: var(--docsy-color-warning-bg, #fffbeb);
  }

  .docsy-callout--danger {
    border-color: var(--docsy-color-danger, #ef4444);
    background: var(--docsy-color-danger-bg, #fef2f2);
  }

  .docsy-callout__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.375rem;
  }

  .docsy-callout__icon {
    font-size: 1.125rem;
    line-height: 1;
  }

  .docsy-callout__title {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--docsy-color-heading, #1e293b);
  }

  .docsy-callout__body {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--docsy-color-text, #334155);
  }

  .docsy-callout__body :global(p:first-child) {
    margin-top: 0;
  }

  .docsy-callout__body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
