---
export interface Props {
  title?: string;
  language?: string;
}

const { title, language } = Astro.props;
const displayTitle = title || language || '';
---

<div class="docsy-code" data-title={displayTitle}>
  {displayTitle && (
    <div class="docsy-code__header">
      <span class="docsy-code__title">{displayTitle}</span>
      <button class="docsy-code__copy" aria-label="Copy code" data-copied="false">
        <svg class="docsy-code__copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        <span class="docsy-code__copy-text">Copy</span>
      </button>
    </div>
  )}
  <div class="docsy-code__body">
    <slot />
  </div>
</div>

<script>
  document.querySelectorAll('.docsy-code__copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const codeBlock = btn.closest('.docsy-code');
      const code = codeBlock?.querySelector('code')?.textContent || '';
      try {
        await navigator.clipboard.writeText(code);
        const textEl = btn.querySelector('.docsy-code__copy-text');
        if (textEl) {
          textEl.textContent = 'Copied!';
          setTimeout(() => {
            textEl.textContent = 'Copy';
          }, 2000);
        }
      } catch (err) {
        console.warn('Failed to copy to clipboard:', err);
      }
    });
  });
</script>

<style>
  .docsy-code {
    margin: 1.5rem 0;
    border: var(--docsy-border, 1px solid #e5e7eb);
    border-radius: var(--docsy-code-radius, var(--docsy-radius-md, 8px));
    overflow: hidden;
  }

  .docsy-code__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--docsy-code-padding, 1rem 1.25rem);
    background: var(--docsy-color-code-header, #334155);
    border-bottom: var(--docsy-border, 1px solid #e5e7eb);
  }

  .docsy-code__title {
    font-size: var(--docsy-code-font-size, 0.8125rem);
    font-family: var(--docsy-font-mono, ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace);
    font-weight: 500;
    color: var(--docsy-color-code-tab-active, #f8fafc);
  }

  .docsy-code__copy {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    border: none;
    background: none;
    color: var(--docsy-color-code-tab, #94a3b8);
    cursor: pointer;
    font-size: var(--docsy-font-size-xs, 0.75rem);
    padding: 0.25rem 0.5rem;
    border-radius: var(--docsy-radius-sm, 6px);
    transition: color var(--docsy-transition-normal, 0.15s ease), background var(--docsy-transition-normal, 0.15s ease);
  }

  .docsy-code__copy:hover {
    color: var(--docsy-color-code-tab-active, #f8fafc);
    background: rgba(255, 255, 255, 0.1);
  }

  .docsy-code__body {
    background: var(--docsy-color-code-bg, #1e293b);
  }

  .docsy-code__body :global(pre) {
    margin: 0;
    border: none;
    border-radius: 0;
  }
</style>
