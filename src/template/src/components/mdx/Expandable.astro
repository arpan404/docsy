---
export interface Props {
  title?: string;
  defaultOpen?: boolean;
}

const { title = 'Show more', defaultOpen = false } = Astro.props;
---

<details class="docsy-expandable" open={defaultOpen}>
  <summary class="docsy-expandable__summary">
    <svg class="docsy-expandable__chevron" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    <span>{title}</span>
  </summary>
  <div class="docsy-expandable__content">
    <slot />
  </div>
</details>

<style>
  .docsy-expandable {
    margin: 1rem 0;
  }

  .docsy-expandable__summary {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--docsy-color-primary, #6366f1);
    list-style: none;
    user-select: none;
  }

  .docsy-expandable__summary::-webkit-details-marker {
    display: none;
  }

  .docsy-expandable__summary::marker {
    display: none;
    content: '';
  }

  .docsy-expandable__chevron {
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .docsy-expandable[open] > .docsy-expandable__summary .docsy-expandable__chevron {
    transform: rotate(90deg);
  }

  .docsy-expandable__content {
    padding: 0.75rem 0 0 1.375rem;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--docsy-color-text, #334155);
  }

  .docsy-expandable__content :global(p:first-child) {
    margin-top: 0;
  }

  .docsy-expandable__content :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
