---
export interface Props {
  name: string;
  defaultOpen?: boolean;
}

const { name, defaultOpen = true } = Astro.props;
---

<li class="docsy-tree-folder" role="treeitem" aria-expanded={String(defaultOpen)}>
  <details open={defaultOpen}>
    <summary class="docsy-tree-folder__label">
      <svg class="docsy-tree-folder__chevron" width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <svg class="docsy-tree-folder__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
      </svg>
      <span>{name}</span>
    </summary>
    <ul role="group">
      <slot />
    </ul>
  </details>
</li>

<style>
  .docsy-tree-folder {
    list-style: none;
  }

  .docsy-tree-folder__label {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    cursor: pointer;
    user-select: none;
    list-style: none;
    color: var(--docsy-color-heading, #1e293b);
  }

  .docsy-tree-folder__label::-webkit-details-marker {
    display: none;
  }

  .docsy-tree-folder__label::marker {
    display: none;
    content: '';
  }

  .docsy-tree-folder__chevron {
    flex-shrink: 0;
    transition: transform 0.15s;
    color: var(--docsy-color-text-muted, #94a3b8);
  }

  details[open] > .docsy-tree-folder__label .docsy-tree-folder__chevron {
    transform: rotate(90deg);
  }

  .docsy-tree-folder__icon {
    flex-shrink: 0;
    color: var(--docsy-color-primary, #6366f1);
  }

  .docsy-tree-folder__label:hover {
    color: var(--docsy-color-primary, #6366f1);
  }
</style>
