---
export interface Props {
  file: string;
}

const { file } = Astro.props;
---

<div class="docsy-snippet" data-title={file}>
  <div class="docsy-snippet__header">
    <svg class="docsy-snippet__file-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
      <polyline points="13 2 13 9 20 9"></polyline>
    </svg>
    <span class="docsy-snippet__filename">{file}</span>
    <button class="docsy-snippet__copy" aria-label="Copy code">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
    </button>
  </div>
  <div class="docsy-snippet__body">
    <slot />
  </div>
</div>

<script>
  document.querySelectorAll('.docsy-snippet__copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const snippet = btn.closest('.docsy-snippet');
      const code = snippet?.querySelector('code')?.textContent || '';
      try {
        await navigator.clipboard.writeText(code);
        (window as any).__docsyTrack?.('docs.code_block.copy', {
          title: snippet?.getAttribute('data-title') || '',
          length: code.length,
        });
        const icon = btn.querySelector('svg');
        if (icon) {
          const original = icon.outerHTML;
          icon.outerHTML =
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
          setTimeout(() => {
            const current = btn.querySelector('svg');
            if (current) current.outerHTML = original;
          }, 2000);
        }
      } catch (err) {
        console.warn('Failed to copy to clipboard:', err);
      }
    });
  });
</script>

<style>
  .docsy-snippet {
    margin: 1.5rem 0;
    border: var(--docsy-border, 1px solid #e5e7eb);
    border-radius: var(--docsy-code-radius, var(--docsy-radius-md, 8px));
    overflow: hidden;
  }

  .docsy-snippet__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: var(--docsy-code-padding, 1rem 1.25rem);
    background: var(--docsy-color-code-header, #334155);
    border-bottom: var(--docsy-border, 1px solid #e5e7eb);
    color: var(--docsy-color-code-tab-active, #e2e8f0);
  }

  .docsy-snippet__file-icon {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .docsy-snippet__filename {
    flex: 1;
    font-size: var(--docsy-code-font-size, 0.8125rem);
    font-family: var(--docsy-font-mono, ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace);
    font-weight: 500;
  }

  .docsy-snippet__copy {
    display: flex;
    align-items: center;
    border: none;
    background: none;
    color: var(--docsy-color-code-tab, #94a3b8);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: var(--docsy-radius-sm, 6px);
    transition: color var(--docsy-transition-normal, 0.15s ease), background var(--docsy-transition-normal, 0.15s ease);
  }

  .docsy-snippet__copy:hover {
    color: var(--docsy-color-code-tab-active, #ffffff);
    background: rgba(255, 255, 255, 0.1);
  }

  .docsy-snippet__body {
    background: var(--docsy-color-code-bg, #1e293b);
  }

  .docsy-snippet__body :global(pre) {
    margin: 0;
    border: none;
    border-radius: 0;
  }
</style>
