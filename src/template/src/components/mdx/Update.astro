---
export interface Props {
  date: string;
  version?: string;
  title?: string;
}

const { date, version, title } = Astro.props;

// Format date for display
let displayDate = date;
try {
  const d = new Date(date);
  if (!isNaN(d.getTime())) {
    displayDate = d.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });
  }
} catch {
  // Use raw date string as fallback
}
---

<article class="docsy-update">
  <div class="docsy-update__meta">
    <time class="docsy-update__date" datetime={date}>{displayDate}</time>
    {version && (
      <span class="docsy-update__version">{version}</span>
    )}
  </div>
  {title && <h3 class="docsy-update__title">{title}</h3>}
  <div class="docsy-update__content">
    <slot />
  </div>
</article>

<style>
  .docsy-update {
    position: relative;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--docsy-color-border, #e2e8f0);
  }

  .docsy-update:last-child {
    border-bottom: none;
  }

  .docsy-update__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .docsy-update__date {
    font-size: 0.8125rem;
    color: var(--docsy-color-text-muted, #64748b);
    font-weight: 500;
  }

  .docsy-update__version {
    display: inline-flex;
    align-items: center;
    font-size: 0.6875rem;
    font-weight: 600;
    font-family: var(--docsy-font-mono, ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace);
    color: var(--docsy-color-primary, #6366f1);
    background: var(--docsy-color-note-bg, #eef2ff);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
  }

  .docsy-update__title {
    margin: 0 0 0.5rem 0;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--docsy-color-heading, #1e293b);
  }

  .docsy-update__content {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--docsy-color-text, #334155);
  }

  .docsy-update__content :global(p:first-child) {
    margin-top: 0;
  }

  .docsy-update__content :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
