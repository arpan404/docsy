---
export interface Props {
  chart?: string;
}

const { chart } = Astro.props;
---

<docsy-mermaid class="docsy-mermaid">
  <pre class="docsy-mermaid__source">{chart}<slot /></pre>
  <div class="docsy-mermaid__render" aria-label="Diagram"></div>
</docsy-mermaid>

<script>
  interface MermaidAPI {
    initialize(config: { startOnLoad: boolean; theme: 'default' | 'dark' }): void;
    render(id: string, code: string): Promise<{ svg: string }>;
  }

  class DocsyMermaid extends HTMLElement {
    async connectedCallback() {
      const source = this.querySelector<HTMLElement>('.docsy-mermaid__source');
      const render = this.querySelector<HTMLElement>('.docsy-mermaid__render');
      if (!source || !render) return;

      const code = source.textContent?.trim();
      if (!code) return;

      try {
        const win = window as Window & { mermaid?: MermaidAPI };

        // Dynamically load mermaid from CDN
        if (!win.mermaid) {
          await new Promise<void>((resolve, reject) => {
            const script = document.createElement('script');
            script.src = 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js';
            script.onload = () => resolve();
            script.onerror = () => reject(new Error('Failed to load mermaid'));
            document.head.appendChild(script);
          });
        }

        const mermaid = win.mermaid;
        if (!mermaid) return;
        const activeTheme = document.documentElement.getAttribute('data-theme');
        const isDark =
          activeTheme === 'dark' ||
          (!activeTheme && window.matchMedia('(prefers-color-scheme: dark)').matches);

        mermaid.initialize({
          startOnLoad: false,
          theme: isDark ? 'dark' : 'default',
        });

        const id = `mermaid-${Math.random().toString(36).slice(2, 8)}`;
        const { svg } = await mermaid.render(id, code);
        if (!svg) return;

        render.innerHTML = svg;
        source.style.display = 'none';
        render.style.display = 'block';
      } catch (err) {
        // On error, leave the source code visible as fallback
        console.warn('Mermaid render failed:', err);
        source.style.display = 'block';
        render.style.display = 'none';
      }
    }
  }

  if (!customElements.get('docsy-mermaid')) {
    customElements.define('docsy-mermaid', DocsyMermaid);
  }
</script>

<style>
  .docsy-mermaid {
    display: block;
    margin: 1.5rem 0;
  }

  .docsy-mermaid__source {
    background: var(--docsy-bg-secondary, #f8fafc);
    border: var(--docsy-border, 1px solid #e5e7eb);
    border-radius: var(--docsy-radius-md, 8px);
    padding: 1rem;
    font-size: var(--docsy-font-size-sm, 0.8125rem);
    color: var(--docsy-text-primary, #111827);
    white-space: pre;
    overflow-x: auto;
  }

  .docsy-mermaid__render {
    display: none;
    text-align: center;
  }

  .docsy-mermaid__render :global(svg) {
    max-width: 100%;
    height: auto;
  }
</style>
