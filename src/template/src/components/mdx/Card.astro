---
import Icon from './Icon.astro';

export interface Props {
  title: string;
  icon?: string;
  iconType?: string;
  href?: string;
  img?: string;
  horizontal?: boolean;
}

const { title, icon, iconType, href, img, horizontal = false } = Astro.props;
---

{href ? (
  <a
    class:list={['docsy-card', { 'docsy-card--horizontal': horizontal, 'docsy-card--link': true }]}
    href={href}
  >
    {img && (
      <div class="docsy-card__img">
        <img src={img} alt="" loading="lazy" />
      </div>
    )}
    <div class="docsy-card__body">
      {icon && (
        <span class="docsy-card__icon">
          <Icon icon={icon} iconType={iconType} />
        </span>
      )}
      <h3 class="docsy-card__title">{title}</h3>
      <div class="docsy-card__content">
        <slot />
      </div>
    </div>
  </a>
) : (
  <div class:list={['docsy-card', { 'docsy-card--horizontal': horizontal }]}>
    {img && (
      <div class="docsy-card__img">
        <img src={img} alt="" loading="lazy" />
      </div>
    )}
    <div class="docsy-card__body">
      {icon && (
        <span class="docsy-card__icon">
          <Icon icon={icon} iconType={iconType} />
        </span>
      )}
      <h3 class="docsy-card__title">{title}</h3>
      <div class="docsy-card__content">
        <slot />
      </div>
    </div>
  </div>
)}

<style>
  .docsy-card {
    display: flex;
    flex-direction: column;
    border: var(--docsy-border-card, var(--docsy-border, 1px solid var(--docsy-border-color, #e5e7eb)));
    border-radius: var(--docsy-card-radius, var(--docsy-radius-md, 8px));
    padding: 0;
    overflow: hidden;
    background: var(--docsy-card-bg, var(--docsy-bg-card, #ffffff));
    box-shadow: var(--docsy-card-shadow, var(--docsy-shadow-sm, none));
    transition: border-color var(--docsy-transition-normal, 0.15s ease),
                box-shadow var(--docsy-transition-normal, 0.15s ease),
                transform var(--docsy-transition-normal, 0.15s ease);
    text-decoration: none;
    color: inherit;
  }

  .docsy-card--link:hover {
    border-color: var(--docsy-border-hover, var(--docsy-color-primary, #6366f1));
    box-shadow: var(--docsy-card-shadow-hover, var(--docsy-shadow-md, 0 4px 12px rgba(0, 0, 0, 0.08)));
    transform: var(--docsy-card-transform-hover, translateY(-1px));
  }

  .docsy-card--horizontal {
    flex-direction: row;
  }

  .docsy-card__img {
    flex-shrink: 0;
  }

  .docsy-card__img img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .docsy-card--horizontal .docsy-card__img {
    width: 40%;
  }

  .docsy-card--horizontal .docsy-card__img img {
    height: 100%;
  }

  .docsy-card__body {
    padding: var(--docsy-card-padding, 1.25rem);
    flex: 1;
  }

  .docsy-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    color: var(--docsy-color-primary, #6366f1);
  }

  .docsy-card__title {
    margin: 0 0 0.5rem 0;
    font-family: var(--docsy-font-headings, inherit);
    font-size: var(--docsy-font-size-base, 1rem);
    font-weight: var(--docsy-heading-weight, 600);
    line-height: 1.4;
    color: var(--docsy-text-primary, #1e293b);
  }

  .docsy-card__content {
    font-size: var(--docsy-font-size-sm, 0.8125rem);
    line-height: 1.6;
    color: var(--docsy-text-secondary, #334155);
  }

  .docsy-card__content :global(p) {
    margin: 0;
  }
</style>
