---
import Icon from './Icon.astro';

export interface Props {
  title: string;
  icon?: string;
  iconType?: string;
  href?: string;
  img?: string;
  horizontal?: boolean;
}

const { title, icon, iconType, href, img, horizontal = false } = Astro.props;
const Tag = href ? 'a' : 'div';
const attrs = href ? { href } : {};
---

<Tag
  class:list={['docsy-card', { 'docsy-card--horizontal': horizontal, 'docsy-card--link': !!href }]}
  {...attrs}
>
  {img && (
    <div class="docsy-card__img">
      <img src={img} alt="" loading="lazy" />
    </div>
  )}
  <div class="docsy-card__body">
    {icon && (
      <span class="docsy-card__icon">
        <Icon icon={icon} iconType={iconType} />
      </span>
    )}
    <h3 class="docsy-card__title">{title}</h3>
    <div class="docsy-card__content">
      <slot />
    </div>
  </div>
</Tag>

<style>
  .docsy-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--docsy-color-border, #e2e8f0);
    border-radius: var(--docsy-radius, 0.5rem);
    padding: 0;
    overflow: hidden;
    background: var(--docsy-color-card-bg, #ffffff);
    transition: border-color 0.2s, box-shadow 0.2s;
    text-decoration: none;
    color: inherit;
  }

  .docsy-card--link:hover {
    border-color: var(--docsy-color-primary, #6366f1);
    box-shadow: 0 2px 8px rgba(99, 102, 241, 0.1);
  }

  .docsy-card--horizontal {
    flex-direction: row;
  }

  .docsy-card__img {
    flex-shrink: 0;
  }

  .docsy-card__img img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .docsy-card--horizontal .docsy-card__img {
    width: 40%;
  }

  .docsy-card--horizontal .docsy-card__img img {
    height: 100%;
  }

  .docsy-card__body {
    padding: 1.25rem;
    flex: 1;
  }

  .docsy-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .docsy-card__title {
    margin: 0 0 0.5rem 0;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--docsy-color-heading, #1e293b);
  }

  .docsy-card__content {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--docsy-color-text-muted, #64748b);
  }

  .docsy-card__content :global(p) {
    margin: 0;
  }
</style>
