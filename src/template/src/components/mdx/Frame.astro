---
export interface Props {
  type?: 'browser' | 'phone' | 'none';
  caption?: string;
}

const { type = 'none', caption } = Astro.props;
---

<figure class:list={['docsy-frame', `docsy-frame--${type}`]}>
  {type === 'browser' && (
    <div class="docsy-frame__browser-chrome">
      <div class="docsy-frame__browser-dots">
        <span class="docsy-frame__dot docsy-frame__dot--red"></span>
        <span class="docsy-frame__dot docsy-frame__dot--yellow"></span>
        <span class="docsy-frame__dot docsy-frame__dot--green"></span>
      </div>
      <div class="docsy-frame__browser-bar"></div>
    </div>
  )}
  {type === 'phone' && (
    <div class="docsy-frame__phone-notch"></div>
  )}
  <div class="docsy-frame__content">
    <slot />
  </div>
  {caption && (
    <figcaption class="docsy-frame__caption">{caption}</figcaption>
  )}
</figure>

<style>
  .docsy-frame {
    margin: 1.5rem 0;
  }

  /* Browser frame */
  .docsy-frame--browser {
    border: var(--docsy-border, 1px solid #e5e7eb);
    border-radius: var(--docsy-radius-lg, 12px);
    overflow: hidden;
  }

  .docsy-frame__browser-chrome {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 1rem;
    background: var(--docsy-color-bg-subtle, #f8fafc);
    border-bottom: 1px solid var(--docsy-color-border, #e2e8f0);
  }

  .docsy-frame__browser-dots {
    display: flex;
    gap: 0.375rem;
  }

  .docsy-frame__dot {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 50%;
  }

  .docsy-frame__dot--red {
    background: #ef4444;
  }

  .docsy-frame__dot--yellow {
    background: #f59e0b;
  }

  .docsy-frame__dot--green {
    background: #22c55e;
  }

  .docsy-frame__browser-bar {
    flex: 1;
    height: 1.5rem;
    background: var(--docsy-color-bg-hover, #f1f5f9);
    border-radius: var(--docsy-radius-sm, 6px);
  }

  /* Phone frame */
  .docsy-frame--phone {
    max-width: 375px;
    margin-left: auto;
    margin-right: auto;
    border: 3px solid var(--docsy-color-border, #1e293b);
    border-radius: 2rem;
    overflow: hidden;
    background: #000;
  }

  .docsy-frame__phone-notch {
    width: 8rem;
    height: 1.5rem;
    background: #000;
    border-radius: 0 0 1rem 1rem;
    margin: 0 auto;
  }

  .docsy-frame__content :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  .docsy-frame__caption {
    text-align: center;
    font-size: var(--docsy-font-size-sm, 0.8125rem);
    color: var(--docsy-color-text-muted, #64748b);
    margin-top: 0.5rem;
    font-style: italic;
  }

  .docsy-frame--browser .docsy-frame__caption,
  .docsy-frame--phone .docsy-frame__caption {
    margin-top: 0.75rem;
  }
</style>
