---
export interface Props {
  tip: string;
}

const { tip } = Astro.props;
---

<span class="docsy-tooltip">
  <slot />
  <span class="docsy-tooltip__tip" role="tooltip">{tip}</span>
</span>

<style>
  .docsy-tooltip {
    position: relative;
    display: inline-block;
    border-bottom: 1px dashed var(--docsy-color-text-muted, #94a3b8);
    cursor: help;
  }

  .docsy-tooltip__tip {
    visibility: hidden;
    opacity: 0;
    position: absolute;
    z-index: 100;
    bottom: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    padding: 0.375rem 0.625rem;
    border-radius: var(--docsy-radius-sm, 6px);
    background: var(--docsy-color-tooltip-bg, #1e293b);
    color: var(--docsy-color-tooltip-text, #f8fafc);
    font-size: var(--docsy-font-size-xs, 0.75rem);
    line-height: 1.4;
    white-space: nowrap;
    pointer-events: none;
    transition: opacity var(--docsy-transition-normal, 0.15s ease), visibility var(--docsy-transition-normal, 0.15s ease);
  }

  .docsy-tooltip__tip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border-width: 5px;
    border-style: solid;
    border-color: var(--docsy-color-tooltip-bg, #1e293b) transparent transparent transparent;
  }

  .docsy-tooltip:hover .docsy-tooltip__tip,
  .docsy-tooltip:focus-within .docsy-tooltip__tip {
    visibility: visible;
    opacity: 1;
  }
</style>
