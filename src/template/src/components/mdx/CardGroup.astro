---
export interface Props {
  cols?: number;
}

const { cols = 2 } = Astro.props;
---

<div class="docsy-card-group" style={`--docsy-card-cols: ${cols}`}>
  <slot />
</div>

<style>
  .docsy-card-group {
    display: grid;
    grid-template-columns: repeat(var(--docsy-card-cols, 2), 1fr);
    gap: var(--docsy-section-gap, 1.5rem);
    margin: 1.5rem 0;
  }

  @media (max-width: 640px) {
    .docsy-card-group {
      grid-template-columns: 1fr;
    }
  }
</style>
