---
export interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<section class="docsy-color-row">
  {title && <h3 class="docsy-color-row__title">{title}</h3>}
  <div class="docsy-color-row__items">
    <slot />
  </div>
</section>

<style>
  .docsy-color-row {
    display: grid;
    gap: 0.5rem;
  }

  .docsy-color-row__title {
    margin: 0;
    font-size: var(--docsy-font-size-sm, 0.875rem);
    font-weight: 650;
    color: var(--docsy-text-primary, #111827);
  }

  .docsy-color-row__items {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
    gap: 0.75rem;
  }
</style>
