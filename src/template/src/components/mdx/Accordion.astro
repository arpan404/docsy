---
export interface Props {
  title: string;
  icon?: string;
  defaultOpen?: boolean;
}

const { title, icon, defaultOpen = false } = Astro.props;
---

<details class="docsy-accordion" open={defaultOpen}>
  <summary class="docsy-accordion__summary">
    {icon && <span class="docsy-accordion__icon">{icon}</span>}
    <span class="docsy-accordion__title">{title}</span>
    <svg class="docsy-accordion__chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </summary>
  <div class="docsy-accordion__content">
    <slot />
  </div>
</details>

<style>
  .docsy-accordion {
    border: 1px solid var(--docsy-color-border, #e2e8f0);
    border-radius: var(--docsy-radius, 0.5rem);
    margin: 0.5rem 0;
    overflow: hidden;
  }

  .docsy-accordion__summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    cursor: pointer;
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--docsy-color-heading, #1e293b);
    background: var(--docsy-color-bg-subtle, #f8fafc);
    list-style: none;
    user-select: none;
    transition: background 0.15s;
  }

  .docsy-accordion__summary::-webkit-details-marker {
    display: none;
  }

  .docsy-accordion__summary::marker {
    display: none;
    content: '';
  }

  .docsy-accordion__summary:hover {
    background: var(--docsy-color-bg-hover, #f1f5f9);
  }

  .docsy-accordion__icon {
    flex-shrink: 0;
    font-size: 1.125rem;
  }

  .docsy-accordion__title {
    flex: 1;
  }

  .docsy-accordion__chevron {
    flex-shrink: 0;
    color: var(--docsy-color-text-muted, #64748b);
    transition: transform 0.2s;
  }

  .docsy-accordion[open] > .docsy-accordion__summary .docsy-accordion__chevron {
    transform: rotate(180deg);
  }

  .docsy-accordion__content {
    padding: 0.75rem 1rem 1rem;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--docsy-color-text, #334155);
  }

  .docsy-accordion__content :global(p:first-child) {
    margin-top: 0;
  }

  .docsy-accordion__content :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
