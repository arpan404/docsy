---
import Icon from './Icon.astro';

export interface Props {
  title: string;
  icon?: string;
  iconType?: string;
  defaultOpen?: boolean;
}

const { title, icon, iconType, defaultOpen = false } = Astro.props;
---

<details class="docsy-accordion" open={defaultOpen}>
  <summary class="docsy-accordion__summary">
    {icon && (
      <span class="docsy-accordion__icon">
        <Icon icon={icon} iconType={iconType} />
      </span>
    )}
    <span class="docsy-accordion__title">{title}</span>
    <svg class="docsy-accordion__chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </summary>
  <div class="docsy-accordion__content">
    <slot />
  </div>
</details>

<style>
  .docsy-accordion {
    border: var(--docsy-border, 1px solid #e5e7eb);
    border-radius: var(--docsy-radius-md, 8px);
    margin: 0.5rem 0;
    overflow: hidden;
  }

  .docsy-accordion__summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    cursor: pointer;
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--docsy-text-primary, #1e293b);
    background: var(--docsy-accordion-header-bg, var(--docsy-bg-secondary, #f9fafb));
    list-style: none;
    user-select: none;
    transition: background var(--docsy-transition-normal, 0.15s ease);
  }

  .docsy-accordion__summary::-webkit-details-marker {
    display: none;
  }

  .docsy-accordion__summary::marker {
    display: none;
    content: '';
  }

  .docsy-accordion__summary:hover {
    background: var(--docsy-accordion-header-hover-bg, var(--docsy-bg-hover, #f1f5f9));
  }

  .docsy-accordion__icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.05rem;
  }

  .docsy-accordion__title {
    flex: 1;
  }

  .docsy-accordion__chevron {
    flex-shrink: 0;
    color: var(--docsy-text-muted, #64748b);
    transition: transform var(--docsy-transition-normal, 0.15s ease);
  }

  .docsy-accordion[open] > .docsy-accordion__summary .docsy-accordion__chevron {
    transform: rotate(180deg);
  }

  .docsy-accordion__content {
    padding: var(--docsy-accordion-content-padding, 0.75rem 1rem 1rem);
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--docsy-text-secondary, #334155);
  }

  .docsy-accordion__content :global(p:first-child) {
    margin-top: 0;
  }

  .docsy-accordion__content :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
