---
export interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="docsy-fields">
  {title && <h4 class="docsy-fields__title">{title}</h4>}
  <div class="docsy-fields__list">
    <slot />
  </div>
</div>

<style>
  .docsy-fields {
    margin: 1.5rem 0;
    border: var(--docsy-border, 1px solid #e5e7eb);
    border-radius: var(--docsy-radius-md, 8px);
    overflow: hidden;
  }

  .docsy-fields__title {
    margin: 0;
    padding: 0.75rem 1rem;
    font-size: var(--docsy-font-size-sm, 0.8125rem);
    font-weight: 600;
    color: var(--docsy-text-primary, #1e293b);
    background: var(--docsy-bg-secondary, #f8fafc);
    border-bottom: var(--docsy-border, 1px solid #e5e7eb);
  }

  .docsy-fields__list {
    padding: 0 1rem;
  }
</style>
