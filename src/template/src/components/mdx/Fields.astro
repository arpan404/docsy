---
export interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="docsy-fields">
  {title && <h4 class="docsy-fields__title">{title}</h4>}
  <div class="docsy-fields__list">
    <slot />
  </div>
</div>

<style>
  .docsy-fields {
    margin: 1.5rem 0;
    border: 1px solid var(--docsy-color-border, #e2e8f0);
    border-radius: var(--docsy-radius, 0.5rem);
    overflow: hidden;
  }

  .docsy-fields__title {
    margin: 0;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--docsy-color-heading, #1e293b);
    background: var(--docsy-color-bg-subtle, #f8fafc);
    border-bottom: 1px solid var(--docsy-color-border, #e2e8f0);
  }

  .docsy-fields__list {
    padding: 0 1rem;
  }
</style>
