---
export interface Props {
  variant?: 'compact' | 'table';
}

const { variant = 'compact' } = Astro.props;
---

<div class:list={['docsy-color', `docsy-color--${variant}`]}>
  <slot />
</div>

<style>
  .docsy-color {
    margin: 1.5rem 0;
  }

  .docsy-color--compact {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
    gap: 0.75rem;
  }

  .docsy-color--table {
    display: grid;
    gap: 1rem;
  }
</style>
