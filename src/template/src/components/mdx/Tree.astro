---
/**
 * Tree - file tree container. Wraps TreeFolder and TreeFile children.
 */
---

<div class="docsy-tree" role="tree">
  <slot />
</div>

<style>
  .docsy-tree {
    margin: 1.5rem 0;
    border: var(--docsy-border, 1px solid #e5e7eb);
    border-radius: var(--docsy-radius-md, 8px);
    padding: 0.75rem 1rem;
    font-family: var(--docsy-font-mono, ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace);
    font-size: var(--docsy-font-size-sm, 0.8125rem);
    line-height: 1.75;
    background: var(--docsy-color-card-bg, #ffffff);
  }

  .docsy-tree :global(ul) {
    list-style: none;
    margin: 0;
    padding-left: 1.25rem;
  }

  .docsy-tree > :global(ul) {
    padding-left: 0;
  }
</style>
