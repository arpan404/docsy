---
export interface Props {
  name: string;
  type: string;
  required?: boolean;
  default?: string;
}

const { name, type, required = false, default: defaultValue } = Astro.props;
---

<div class="docsy-response-field">
  <div class="docsy-response-field__header">
    <code class="docsy-response-field__name">{name}</code>
    <span class="docsy-response-field__type">{type}</span>
    {required && <span class="docsy-response-field__required">required</span>}
    {defaultValue && (
      <span class="docsy-response-field__default">
        default: <code>{defaultValue}</code>
      </span>
    )}
  </div>
  <div class="docsy-response-field__desc">
    <slot />
  </div>
</div>

<style>
  .docsy-response-field {
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--docsy-color-border, #e2e8f0);
  }

  .docsy-response-field:last-child {
    border-bottom: none;
  }

  .docsy-response-field__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.375rem;
  }

  .docsy-response-field__name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--docsy-color-heading, #1e293b);
    background: var(--docsy-color-bg-subtle, #f1f5f9);
    padding: 0.0625rem 0.375rem;
    border-radius: 0.25rem;
  }

  .docsy-response-field__type {
    font-size: 0.75rem;
    font-family: var(--docsy-font-mono, ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace);
    color: var(--docsy-color-primary, #6366f1);
    background: var(--docsy-color-note-bg, #eef2ff);
    padding: 0.0625rem 0.375rem;
    border-radius: 0.25rem;
  }

  .docsy-response-field__required {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.025em;
    color: #dc2626;
    background: #fef2f2;
    padding: 0.0625rem 0.375rem;
    border-radius: 0.25rem;
  }

  .docsy-response-field__default {
    font-size: 0.75rem;
    color: var(--docsy-color-text-muted, #64748b);
  }

  .docsy-response-field__default code {
    font-size: 0.75rem;
    background: var(--docsy-color-bg-subtle, #f1f5f9);
    padding: 0 0.25rem;
    border-radius: 0.25rem;
  }

  .docsy-response-field__desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--docsy-color-text, #334155);
  }

  .docsy-response-field__desc :global(p) {
    margin: 0;
  }
</style>
