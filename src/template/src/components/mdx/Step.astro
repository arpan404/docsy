---
export interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="docsy-step">
  <div class="docsy-step__indicator" aria-hidden="true"></div>
  {title && <h3 class="docsy-step__title">{title}</h3>}
  <div class="docsy-step__content">
    <slot />
  </div>
</div>

<style>
  .docsy-step {
    position: relative;
    padding-bottom: 1.5rem;
    counter-increment: docsy-step;
  }

  .docsy-step:last-child {
    padding-bottom: 0;
  }

  .docsy-step__indicator {
    position: absolute;
    left: -2.5rem;
    top: 0.125rem;
    width: var(--docsy-steps-number-size, 1.75rem);
    height: var(--docsy-steps-number-size, 1.75rem);
    border-radius: 50%;
    background: var(--docsy-steps-number-bg, var(--docsy-color-primary, #6366f1));
    color: var(--docsy-steps-number-color, white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--docsy-font-size-xs, 0.75rem);
    font-weight: 700;
    z-index: 1;
  }

  .docsy-step__indicator::after {
    content: counter(docsy-step);
  }

  .docsy-step__title {
    margin: 0 0 0.5rem 0;
    font-family: var(--docsy-font-headings, inherit);
    font-size: var(--docsy-font-size-base, 1rem);
    font-weight: var(--docsy-heading-weight, 600);
    line-height: var(--docsy-steps-number-size, 1.75rem);
    color: var(--docsy-text-primary, #1e293b);
  }

  .docsy-step__content {
    font-size: var(--docsy-font-size-sm, 0.8125rem);
    line-height: 1.6;
    color: var(--docsy-text-secondary, #334155);
  }

  .docsy-step__content :global(p:first-child) {
    margin-top: 0;
  }

  .docsy-step__content :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
