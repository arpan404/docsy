---
import config from 'virtual:docsy/config';

interface Props {
  sourcePath?: string;
}

const { sourcePath } = Astro.props;
const feedback = config.feedback;
const repoUrl = findGithubRepoUrl([
  feedback?.githubRepo,
  feedback?.repository,
  config.repository,
  config.repo,
  config.topbarCtaButton?.href,
  typeof config.logo === 'object' ? config.logo.href : undefined,
  config.footer?.socials?.github,
  config.footerSocials?.github,
]);
const pagePath = Astro.url.pathname;
const title = `Documentation feedback: ${pagePath}`;
const docsPath = trimSlashes(feedback?.docsPath || config.docsPath || 'docs');
const filePath = normalizeSourcePath(sourcePath || `${trimSlashes(pagePath) || 'index'}.mdx`, docsPath);
const editUrl = resolveEditUrl();
const issueUrl = resolveIssueUrl();
const showThumbs = feedback?.thumbsRating === true;
const showSuggestEdit = !!feedback?.suggestEdit && !!editUrl;
const showRaiseIssue = !!feedback?.raiseIssue && !!issueUrl;
const enabled = showThumbs || showSuggestEdit || showRaiseIssue;

function findGithubRepoUrl(candidates: Array<unknown>): string | undefined {
  for (const candidate of candidates) {
    if (typeof candidate !== 'string' || !candidate) continue;
    const normalized = normalizeGithubRepo(candidate);
    if (normalized) return normalized;
  }
  return undefined;
}

function normalizeGithubRepo(value: string): string | undefined {
  const trimmed = value.trim().replace(/\.git$/, '').replace(/\/$/, '');
  const shorthand = /^([\w.-]+)\/([\w.-]+)$/.exec(trimmed);
  if (shorthand) return `https://github.com/${shorthand[1]}/${shorthand[2]}`;

  try {
    const url = new URL(trimmed);
    if (url.hostname !== 'github.com') return undefined;
    const [owner, repo] = url.pathname.split('/').filter(Boolean);
    if (!owner || !repo) return undefined;
    return `https://github.com/${owner}/${repo}`;
  } catch {
    return undefined;
  }
}

function trimSlashes(value: string): string {
  return value.replace(/^\/+|\/+$/g, '');
}

function normalizeSourcePath(value: string, basePath: string): string {
  const cleaned = trimSlashes(value);
  const withExt = /\.[cm]?mdx?$/.test(cleaned) ? cleaned : `${cleaned}.mdx`;
  if (!basePath || withExt === basePath || withExt.startsWith(`${basePath}/`)) return withExt;
  return `${basePath}/${withExt}`;
}

function applyTemplate(url: string): string {
  return url
    .replace(/\{path\}/g, encodeURIComponent(filePath))
    .replace(/\{sourcePath\}/g, encodeURIComponent(filePath))
    .replace(/\{page\}/g, encodeURIComponent(pagePath));
}

function resolveEditUrl(): string | undefined {
  if (typeof feedback?.suggestEdit === 'string') return applyTemplate(feedback.suggestEdit);
  if (feedback?.editBaseUrl) return `${feedback.editBaseUrl.replace(/\/$/, '')}/${filePath}`;
  if (!repoUrl) return undefined;
  const branch = feedback?.suggestEditBranch || config.branch || 'main';
  return `${repoUrl}/edit/${encodeURIComponent(branch)}/${filePath}`;
}

function resolveIssueUrl(): string | undefined {
  if (typeof feedback?.raiseIssue === 'string') return applyTemplate(feedback.raiseIssue);
  const baseUrl = feedback?.issueBaseUrl || (repoUrl ? `${repoUrl}/issues/new` : undefined);
  if (!baseUrl) return undefined;

  const url = new URL(baseUrl);
  url.searchParams.set('title', title);
  url.searchParams.set('body', [
    `Page: ${pagePath}`,
    `Source: ${filePath}`,
    '',
    'Describe the issue:',
  ].join('\n'));
  return url.toString();
}
---

{enabled && (
  <section class="docsy-feedback" data-page-feedback data-page-path={pagePath} data-source-path={filePath} aria-labelledby="docsy-feedback-title">
    <h2 class="docsy-feedback__title" id="docsy-feedback-title">Was this page helpful?</h2>
    {showThumbs && (
      <div class="docsy-feedback__actions" role="group" aria-label="Rate this page">
        <button class="docsy-feedback__button" type="button" data-feedback-value="positive">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M7 10v11H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3Zm0 0 4.5-7a2 2 0 0 1 3.6 1.2L14 9h5.1a2 2 0 0 1 2 2.3l-1.2 8a2 2 0 0 1-2 1.7H7V10Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
          </svg>
          <span>Yes</span>
        </button>
        <button class="docsy-feedback__button" type="button" data-feedback-value="negative">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M17 14V3h3a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2h-3Zm0 0-4.5 7a2 2 0 0 1-3.6-1.2L10 15H4.9a2 2 0 0 1-2-2.3l1.2-8a2 2 0 0 1 2-1.7H17v11Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
          </svg>
          <span>No</span>
        </button>
      </div>
    )}
    {(showSuggestEdit || showRaiseIssue) && (
      <div class="docsy-feedback__links">
        {showSuggestEdit && (
          <a class="docsy-feedback__link" href={editUrl} target="_blank" rel="noopener noreferrer" data-feedback-action="suggest_edit">
            Suggest edits
          </a>
        )}
        {showRaiseIssue && (
          <a class="docsy-feedback__link" href={issueUrl} target="_blank" rel="noopener noreferrer" data-feedback-action="raise_issue">
            Raise issue
          </a>
        )}
      </div>
    )}
    <p class="docsy-feedback__thanks" data-feedback-thanks hidden>Thanks for the feedback.</p>
  </section>
)}

<script>
  function initPageFeedback() {
    document.querySelectorAll<HTMLElement>('[data-page-feedback]').forEach((root) => {
      if (root.dataset.initialized === 'true') return;
      root.dataset.initialized = 'true';

      const pagePath = root.dataset.pagePath || window.location.pathname;
      const sourcePath = root.dataset.sourcePath || '';
      const storageKey = `docsy-feedback:${pagePath}`;
      const buttons = root.querySelectorAll<HTMLButtonElement>('[data-feedback-value]');
      const thanks = root.querySelector<HTMLElement>('[data-feedback-thanks]');
      const stored = localStorage.getItem(storageKey);

      function select(value: string, shouldTrack: boolean) {
        buttons.forEach((button) => {
          const isSelected = button.dataset.feedbackValue === value;
          button.classList.toggle('selected', isSelected);
          button.setAttribute('aria-pressed', String(isSelected));
        });

        if (thanks) thanks.hidden = false;

        if (shouldTrack) {
          localStorage.setItem(storageKey, value);
          (window as any).__docsyTrack?.(
            value === 'positive' ? 'docs.feedback.thumbs_up' : 'docs.feedback.thumbs_down',
            {
              rating: value,
              path: pagePath,
            },
          );
        }
      }

      if (stored) select(stored, false);

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const value = button.dataset.feedbackValue || 'positive';
          select(value, true);
        });
      });

      root.querySelectorAll<HTMLAnchorElement>('[data-feedback-action]').forEach((link) => {
        link.addEventListener('click', () => {
          const action = link.dataset.feedbackAction || '';
          (window as any).__docsyTrack?.(
            action === 'suggest_edit' ? 'docs.feedback.suggest_edit' : 'docs.feedback.raise_issue',
            {
              action,
              path: pagePath,
              sourcePath,
              href: link.href,
            },
          );
        });
      });
    });
  }

  initPageFeedback();
  document.addEventListener('astro:after-swap', initPageFeedback);
</script>

<style>
  .docsy-feedback {
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: var(--docsy-border, 1px solid #e5e7eb);
  }

  .docsy-feedback__title {
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--docsy-text-primary, #111827);
  }

  .docsy-feedback__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .docsy-feedback__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    min-height: 34px;
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--docsy-border-color, #e5e7eb);
    border-radius: var(--docsy-radius-sm, 6px);
    background: var(--docsy-bg-primary, #ffffff);
    color: var(--docsy-text-secondary, #6b7280);
    font: inherit;
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color var(--docsy-transition-normal, 0.15s ease), color var(--docsy-transition-normal, 0.15s ease), background var(--docsy-transition-normal, 0.15s ease);
  }

  .docsy-feedback__button:hover,
  .docsy-feedback__button.selected {
    border-color: var(--docsy-color-primary, #6366f1);
    color: var(--docsy-color-primary, #6366f1);
    background: var(--docsy-bg-secondary, #f9fafb);
  }

  .docsy-feedback__button:focus-visible {
    outline: 2px solid var(--docsy-color-primary, #6366f1);
    outline-offset: 2px;
  }

  .docsy-feedback__links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  .docsy-feedback__link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--docsy-text-secondary, #6b7280);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color var(--docsy-transition-normal, 0.15s ease), border-color var(--docsy-transition-normal, 0.15s ease);
  }

  .docsy-feedback__link:hover {
    color: var(--docsy-color-primary, #6366f1);
    border-color: currentColor;
  }

  .docsy-feedback__thanks {
    margin: 0.75rem 0 0;
    font-size: 0.8125rem;
    color: var(--docsy-text-muted, #9ca3af);
  }
</style>
