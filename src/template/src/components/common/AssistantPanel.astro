---
import config from 'virtual:docsy/config';

const assistantConfig = typeof config.assistant === 'object' ? config.assistant : {};
const placeholder = assistantConfig.placeholder || 'Ask a question about these docs...';
const suggestedQuestions = Array.isArray(assistantConfig.suggestedQuestions)
  ? assistantConfig.suggestedQuestions
  : [];
const contactEmail = assistantConfig.contactEmail || '';
const rawAssistantApi = assistantConfig.api || '';
const assistantApiConfig = typeof rawAssistantApi === 'string'
  ? { endpoint: rawAssistantApi, method: 'POST', headers: {} }
  : {
      endpoint: rawAssistantApi.endpoint || '',
      method: rawAssistantApi.method || 'POST',
      headers: rawAssistantApi.headers || {},
      timeoutMs: rawAssistantApi.timeoutMs,
    };
const ragConfig = assistantConfig.rag || {};
const assistantApi = assistantApiConfig.endpoint || '';
const maxResults = ragConfig.maxResults || 4;
const maxCharsPerSource = ragConfig.maxCharsPerSource || 8000;
const includeFullMarkdown = ragConfig.includeFullMarkdown !== false;
const contextRoute = ragConfig.contextRoute || '/assistant-context.json';
---

<div
  class="docsy-assistant"
  id="docsy-assistant"
  data-assistant
  data-assistant-api={assistantApi}
  data-assistant-api-config={JSON.stringify(assistantApiConfig)}
  data-contact-email={contactEmail}
  data-max-results={maxResults}
  data-max-chars-per-source={maxCharsPerSource}
  data-include-full-markdown={String(includeFullMarkdown)}
  data-context-route={contextRoute}
  aria-hidden="true"
>
  <div class="docsy-assistant__backdrop" data-assistant-close></div>
  <aside class="docsy-assistant__panel" role="dialog" aria-modal="true" aria-labelledby="docsy-assistant-title">
    <header class="docsy-assistant__header">
      <div>
        <p class="docsy-assistant__eyebrow">Assistant</p>
        <h2 class="docsy-assistant__title" id="docsy-assistant-title">Ask these docs</h2>
      </div>
      <button class="docsy-assistant__icon-button" type="button" data-assistant-close aria-label="Close assistant">
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
          <path d="M4 4l8 8M12 4l-8 8" />
        </svg>
      </button>
    </header>

    <div class="docsy-assistant__messages" data-assistant-messages aria-live="polite">
      <div class="docsy-assistant__message docsy-assistant__message--assistant">
        <p>Ask a question and I will search the documentation, summarize the relevant pages, and cite sources.</p>
      </div>
      {suggestedQuestions.length > 0 && (
        <div class="docsy-assistant__suggestions" aria-label="Suggested questions">
          {suggestedQuestions.map((question) => (
            <button class="docsy-assistant__suggestion" type="button" data-assistant-suggestion={question}>
              {question}
            </button>
          ))}
        </div>
      )}
    </div>

    <form class="docsy-assistant__form" data-assistant-form>
      <textarea
        class="docsy-assistant__input"
        data-assistant-input
        rows="2"
        placeholder={placeholder}
        autocomplete="off"
      ></textarea>
      <button class="docsy-assistant__send" type="submit" aria-label="Send question">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 2 11 13" />
          <path d="m22 2-7 20-4-9-9-4 20-7Z" />
        </svg>
      </button>
    </form>
  </aside>
</div>

<script>
  interface SearchEntry {
    slug: string;
    title: string;
    description: string;
    headings: string[];
    content: string;
    lang?: string;
  }

  interface AssistantResult {
    entry: SearchEntry;
    score: number;
    markdown: string;
    excerpt: string;
  }

  interface AssistantApiConfig {
    endpoint: string;
    method: 'POST' | 'PUT';
    headers: Record<string, string>;
    timeoutMs?: number;
  }

  let assistantSearchIndex: { entries: SearchEntry[] } | null = null;

  function initAssistant() {
    const root = document.querySelector<HTMLElement>('[data-assistant]');
    if (!root || root.dataset.assistantInitialized === 'true') return;
    root.dataset.assistantInitialized = 'true';

    const messages = root.querySelector<HTMLElement>('[data-assistant-messages]');
    const form = root.querySelector<HTMLFormElement>('[data-assistant-form]');
    const input = root.querySelector<HTMLTextAreaElement>('[data-assistant-input]');
    const apiConfig = readAssistantApiConfig(root);
    const contactEmail = root.dataset.contactEmail || '';
    const maxResults = numberFromDataset(root.dataset.maxResults, 4);
    const maxCharsPerSource = numberFromDataset(root.dataset.maxCharsPerSource, 8000);
    const includeFullMarkdown = root.dataset.includeFullMarkdown !== 'false';
    const contextRoute = root.dataset.contextRoute || '/assistant-context.json';

    function track(eventName: string, properties?: Record<string, unknown>) {
      (window as any).__docsyTrack?.(eventName, properties);
    }

    function openAssistant(detail?: { markdown?: string; title?: string; markdownUrl?: string }) {
      root.classList.add('docsy-assistant--open');
      root.setAttribute('aria-hidden', 'false');
      document.documentElement.classList.add('docsy-assistant-open');
      input?.focus();
      track('docs.assistant.open', {
        title: detail?.title || document.title,
        markdownUrl: detail?.markdownUrl || '',
        source: detail?.markdown ? 'contextual_menu' : 'button',
      });
    }

    function closeAssistant() {
      root.classList.remove('docsy-assistant--open');
      root.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.remove('docsy-assistant-open');
      track('docs.assistant.close');
    }

    (window as any).__docsyOpenAssistant = openAssistant;
    window.addEventListener('docsy:assistant:open', ((event: CustomEvent) => {
      openAssistant(event.detail);
    }) as EventListener);

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      if (target.closest('[data-assistant-trigger]')) {
        event.preventDefault();
        openAssistant();
      }

      if (target.closest('[data-assistant-close]')) {
        event.preventDefault();
        closeAssistant();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && root.classList.contains('docsy-assistant--open')) {
        closeAssistant();
      }
    });

    root.querySelectorAll<HTMLButtonElement>('[data-assistant-suggestion]').forEach((button) => {
      button.addEventListener('click', () => {
        if (!input) return;
        input.value = button.dataset.assistantSuggestion || '';
        form?.requestSubmit();
      });
    });

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const query = input?.value.trim() || '';
      if (!query || !messages) return;

      appendMessage(messages, 'user', query);
      if (input) input.value = '';

      const pending = appendMessage(messages, 'assistant', 'Searching documentation...');
      track('docs.assistant.query', { query });

      try {
        const results = await queryDocs(query, {
          maxResults,
          maxCharsPerSource,
          includeFullMarkdown,
        });
        const apiAnswer = apiConfig.endpoint ? await askAssistantApi(apiConfig, query, results, contextRoute) : null;
        pending.remove();

        if (apiAnswer) {
          appendMessage(messages, 'assistant', apiAnswer.answer, apiAnswer.sources || results);
          track('docs.assistant.response', { query, results: apiAnswer.sources?.length || results.length, mode: 'api' });
          return;
        }

        const answer = buildLocalAnswer(query, results, contactEmail);
        appendMessage(messages, 'assistant', answer.text, results);
        track('docs.assistant.response', { query, results: results.length, mode: 'local' });
      } catch (error) {
        pending.remove();
        appendMessage(messages, 'assistant', fallbackText(contactEmail));
        track('docs.assistant.error', { query, message: error instanceof Error ? error.message : String(error) });
      }
    });
  }

  function appendMessage(container: HTMLElement, role: 'user' | 'assistant', text: string, sources: AssistantResult[] = []): HTMLElement {
    const message = document.createElement('div');
    message.className = `docsy-assistant__message docsy-assistant__message--${role}`;
    message.innerHTML = `<p>${escapeHtml(text).replace(/\n/g, '<br>')}</p>`;

    if (sources.length > 0) {
      const list = document.createElement('ol');
      list.className = 'docsy-assistant__sources';
      for (const source of sources.slice(0, 4)) {
        const item = document.createElement('li');
        item.innerHTML = `<a href="/${escapeHtml(source.entry.slug)}" data-assistant-source>${escapeHtml(source.entry.title)}</a>`;
        list.appendChild(item);
      }
      message.appendChild(list);
    }

    container.appendChild(message);
    container.scrollTop = container.scrollHeight;
    return message;
  }

  async function loadAssistantSearchIndex(): Promise<{ entries: SearchEntry[] }> {
    if (assistantSearchIndex) return assistantSearchIndex;
    const mod = await import('virtual:docsy/search');
    assistantSearchIndex = mod.default as { entries: SearchEntry[] };
    return assistantSearchIndex;
  }

  async function queryDocs(query: string, options: {
    maxResults: number;
    maxCharsPerSource: number;
    includeFullMarkdown: boolean;
  }): Promise<AssistantResult[]> {
    const index = await loadAssistantSearchIndex();
    const terms = query.toLowerCase().split(/\s+/).filter(Boolean);
    const scored = index.entries
      .map((entry) => ({ entry, score: scoreEntry(entry, terms) }))
      .filter((result) => result.score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, options.maxResults);

    const results: AssistantResult[] = [];
    for (const result of scored) {
      const fetchedMarkdown = options.includeFullMarkdown ? await fetchMarkdown(result.entry.slug) : '';
      const markdown = truncateForContext(fetchedMarkdown, options.maxCharsPerSource);
      results.push({
        ...result,
        markdown,
        excerpt: excerptFor(markdown || result.entry.content || result.entry.description, terms),
      });
    }

    return results;
  }

  function scoreEntry(entry: SearchEntry, terms: string[]): number {
    const title = entry.title.toLowerCase();
    const description = entry.description.toLowerCase();
    const headings = entry.headings.join(' ').toLowerCase();
    const content = entry.content.toLowerCase();
    const slug = entry.slug.toLowerCase();
    let score = 0;

    for (const term of terms) {
      if (title.includes(term)) score += 60;
      if (headings.includes(term)) score += 35;
      if (description.includes(term)) score += 25;
      if (content.includes(term)) score += 15;
      if (slug.includes(term)) score += 20;
    }

    return score;
  }

  async function fetchMarkdown(slug: string): Promise<string> {
    const response = await fetch(`/${slug}.md`);
    return response.ok ? await response.text() : '';
  }

  async function askAssistantApi(
    api: AssistantApiConfig,
    query: string,
    results: AssistantResult[],
    contextRoute: string,
  ): Promise<{ answer: string; sources?: AssistantResult[] } | null> {
    const controller = typeof AbortController !== 'undefined' ? new AbortController() : null;
    const timeout = api.timeoutMs && controller
      ? window.setTimeout(() => controller.abort(), api.timeoutMs)
      : null;

    let response: Response;
    try {
      response = await fetch(api.endpoint, {
        method: api.method || 'POST',
        headers: { 'Content-Type': 'application/json', ...(api.headers || {}) },
        signal: controller?.signal,
        body: JSON.stringify({
          query,
          path: window.location.pathname,
          url: window.location.href,
          title: document.title,
          contextRoute,
          context: results.map((result) => ({
            slug: result.entry.slug,
            title: result.entry.title,
            description: result.entry.description,
            headings: result.entry.headings,
            score: result.score,
            excerpt: result.excerpt,
            markdownUrl: `/${result.entry.slug}.md`,
            markdown: result.markdown,
          })),
        }),
      });
    } finally {
      if (timeout) window.clearTimeout(timeout);
    }

    if (!response.ok) return null;
    const data = await response.json();
    if (!data || typeof data.answer !== 'string') return null;
    return { answer: data.answer, sources: results };
  }

  function readAssistantApiConfig(root: HTMLElement): AssistantApiConfig {
    const fallback = {
      endpoint: root.dataset.assistantApi || '',
      method: 'POST' as const,
      headers: {},
    };

    if (!root.dataset.assistantApiConfig) return fallback;

    try {
      const parsed = JSON.parse(root.dataset.assistantApiConfig);
      return {
        endpoint: typeof parsed.endpoint === 'string' ? parsed.endpoint : fallback.endpoint,
        method: parsed.method === 'PUT' ? 'PUT' : 'POST',
        headers: parsed.headers && typeof parsed.headers === 'object' ? parsed.headers : {},
        timeoutMs: typeof parsed.timeoutMs === 'number' ? parsed.timeoutMs : undefined,
      };
    } catch {
      return fallback;
    }
  }

  function numberFromDataset(value: string | undefined, fallback: number): number {
    const parsed = Number(value);
    return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;
  }

  function truncateForContext(value: string, maxChars: number): string {
    if (!value || value.length <= maxChars) return value;
    return `${value.slice(0, maxChars).trimEnd()}\n\n[truncated]`;
  }

  function buildLocalAnswer(query: string, results: AssistantResult[], contactEmail: string): { text: string } {
    if (results.length === 0) {
      return { text: fallbackText(contactEmail) };
    }

    const lines = [
      `I found ${results.length === 1 ? 'one relevant page' : `${results.length} relevant pages`} for "${query}".`,
      '',
      ...results.slice(0, 3).map((result, index) => `${index + 1}. ${result.entry.title}: ${result.excerpt || result.entry.description || result.entry.slug}`),
      '',
      'Open the sources below for the full context.',
    ];

    return { text: lines.join('\n') };
  }

  function fallbackText(contactEmail: string): string {
    return contactEmail
      ? `I could not find enough information in these docs to answer that. Contact ${contactEmail} for help.`
      : 'I could not find enough information in these docs to answer that.';
  }

  function excerptFor(value: string, terms: string[]): string {
    const normalized = value.replace(/\s+/g, ' ').trim();
    if (!normalized) return '';
    const lower = normalized.toLowerCase();
    const firstMatch = terms.map((term) => lower.indexOf(term)).filter((index) => index >= 0).sort((a, b) => a - b)[0] ?? 0;
    const start = Math.max(0, firstMatch - 80);
    const end = Math.min(normalized.length, firstMatch + 260);
    return `${start > 0 ? '...' : ''}${normalized.slice(start, end)}${end < normalized.length ? '...' : ''}`;
  }

  function escapeHtml(value: string): string {
    const div = document.createElement('div');
    div.textContent = value;
    return div.innerHTML;
  }

  initAssistant();
  document.addEventListener('astro:after-swap', initAssistant);
</script>

<style>
  .docsy-assistant {
    position: fixed;
    inset: 0;
    z-index: 200;
    pointer-events: none;
  }

  .docsy-assistant__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.28);
    opacity: 0;
    transition: opacity 0.16s ease;
  }

  .docsy-assistant__panel {
    position: absolute;
    top: 0;
    right: 0;
    display: grid;
    grid-template-rows: auto 1fr auto;
    width: min(440px, 100vw);
    height: 100vh;
    background: var(--docsy-bg-primary, #ffffff);
    border-left: var(--docsy-border, 1px solid #e5e7eb);
    box-shadow: var(--docsy-shadow-xl, 0 20px 25px -5px rgba(0, 0, 0, 0.1));
    transform: translateX(100%);
    transition: transform 0.18s ease;
  }

  .docsy-assistant--open {
    pointer-events: auto;
  }

  .docsy-assistant--open .docsy-assistant__backdrop {
    opacity: 1;
  }

  .docsy-assistant--open .docsy-assistant__panel {
    transform: translateX(0);
  }

  .docsy-assistant__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
    border-bottom: var(--docsy-border, 1px solid #e5e7eb);
  }

  .docsy-assistant__eyebrow {
    margin: 0 0 0.125rem 0;
    font-size: var(--docsy-font-size-xs, 0.75rem);
    font-weight: 650;
    color: var(--docsy-color-primary, #6366f1);
  }

  .docsy-assistant__title {
    margin: 0;
    font-size: var(--docsy-font-size-lg, 1.125rem);
    line-height: 1.3;
  }

  .docsy-assistant__icon-button,
  .docsy-assistant__send {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: var(--docsy-border, 1px solid #e5e7eb);
    border-radius: var(--docsy-radius-md, 8px);
    background: var(--docsy-bg-primary, #ffffff);
    color: var(--docsy-text-secondary, #6b7280);
    cursor: pointer;
  }

  .docsy-assistant__icon-button:hover,
  .docsy-assistant__send:hover {
    background: var(--docsy-bg-hover, #f3f4f6);
    color: var(--docsy-text-primary, #111827);
  }

  .docsy-assistant__messages {
    min-height: 0;
    overflow-y: auto;
    padding: 1rem;
  }

  .docsy-assistant__message {
    max-width: 92%;
    margin-bottom: 0.75rem;
    padding: 0.75rem 0.875rem;
    border-radius: var(--docsy-radius-md, 8px);
    font-size: var(--docsy-font-size-sm, 0.875rem);
    line-height: 1.55;
  }

  .docsy-assistant__message p {
    margin: 0;
  }

  .docsy-assistant__message--assistant {
    background: var(--docsy-bg-secondary, #f9fafb);
    color: var(--docsy-text-primary, #111827);
  }

  .docsy-assistant__message--user {
    margin-left: auto;
    background: var(--docsy-color-primary, #6366f1);
    color: #ffffff;
  }

  .docsy-assistant__suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.25rem 0 1rem;
  }

  .docsy-assistant__suggestion {
    border: var(--docsy-border, 1px solid #e5e7eb);
    border-radius: var(--docsy-radius-md, 8px);
    background: var(--docsy-bg-primary, #ffffff);
    color: var(--docsy-text-secondary, #6b7280);
    padding: 0.375rem 0.625rem;
    font-size: var(--docsy-font-size-xs, 0.75rem);
    cursor: pointer;
  }

  .docsy-assistant__suggestion:hover {
    color: var(--docsy-text-primary, #111827);
    background: var(--docsy-bg-hover, #f3f4f6);
  }

  .docsy-assistant__sources {
    margin: 0.625rem 0 0 1.125rem;
    padding: 0;
  }

  .docsy-assistant__sources a {
    color: var(--docsy-color-primary, #6366f1);
    text-decoration: none;
  }

  .docsy-assistant__sources a:hover {
    text-decoration: underline;
  }

  .docsy-assistant__form {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.625rem;
    padding: 1rem;
    border-top: var(--docsy-border, 1px solid #e5e7eb);
  }

  .docsy-assistant__input {
    width: 100%;
    min-height: 2.75rem;
    max-height: 9rem;
    resize: vertical;
    border: var(--docsy-border, 1px solid #e5e7eb);
    border-radius: var(--docsy-radius-md, 8px);
    padding: 0.625rem 0.75rem;
    color: var(--docsy-text-primary, #111827);
    background: var(--docsy-bg-primary, #ffffff);
    font: inherit;
    line-height: 1.45;
  }

  .docsy-assistant__input:focus {
    border-color: var(--docsy-color-primary, #6366f1);
    outline: 2px solid color-mix(in srgb, var(--docsy-color-primary, #6366f1) 18%, transparent);
  }

  .docsy-assistant-open {
    overflow: hidden;
  }
</style>
