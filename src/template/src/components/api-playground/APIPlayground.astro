---
/**
 * API Playground - Interactive API testing component for documentation pages.
 *
 * Accepts either separate `method` + `endpoint` props, or a combined `api` string
 * in the format "GET /v1/users" (matching the frontmatter `api` field convention).
 *
 * Uses a custom element (<docsy-api-playground>) for client-side interactivity.
 */
export interface Props {
  /** HTTP method, e.g. "GET", "POST", "PUT", "PATCH", "DELETE" */
  method?: string;
  /** API endpoint path, e.g. "/v1/users/:id" */
  endpoint?: string;
  /** Combined method + endpoint string, e.g. "GET /v1/users/:id" */
  api?: string;
  /** Base URL for the API, e.g. "https://api.example.com" */
  baseUrl?: string;
  /** Whether to route requests through same-origin proxy path/rewrites */
  proxy?: boolean;
  /** Preferred code example languages from config.api.examples.languages */
  exampleLanguages?: string[];
  /** Default values for path params keyed by param name */
  defaultPathParams?: Record<string, string>;
  /** Default key/value rows for query params */
  defaultQueryParams?: Array<{ key: string; value: string }>;
  /** Default key/value rows for headers */
  defaultHeaders?: Array<{ key: string; value: string }>;
  /** Default request body string */
  defaultBody?: string;
  /** Suppress initial blank query row when endpoint has zero OpenAPI query params */
  hideEmptyQueryRow?: boolean;
}

const {
  api,
  baseUrl = '',
  defaultPathParams = {},
  defaultQueryParams = [],
  defaultHeaders = [],
  defaultBody = '',
  hideEmptyQueryRow = false,
  proxy = false,
  exampleLanguages = ['curl', 'python', 'javascript'],
} = Astro.props;
let { method = '', endpoint = '' } = Astro.props;

// Parse combined api string if method/endpoint not provided separately
if (api && !method) {
  const parts = api.trim().split(/\s+/);
  if (parts.length >= 2) {
    method = parts[0].toUpperCase();
    endpoint = parts.slice(1).join(' ');
  } else {
    endpoint = api;
  }
}

method = method.toUpperCase();

const methodColors: Record<string, string> = {
  GET: '#22c55e',
  POST: '#3b82f6',
  PUT: '#f59e0b',
  PATCH: '#f59e0b',
  DELETE: '#ef4444',
};
const methodColor = methodColors[method] || 'var(--docsy-color-primary, #6366f1)';

// Extract path parameters from endpoint (e.g. :id, {id})
const pathParams: string[] = [];
const colonMatches = endpoint.match(/:([a-zA-Z_][a-zA-Z0-9_]*)/g);
if (colonMatches) {
  colonMatches.forEach((m) => pathParams.push(m.slice(1)));
}
const braceMatches = endpoint.match(/\{([a-zA-Z_][a-zA-Z0-9_]*)\}/g);
if (braceMatches) {
  braceMatches.forEach((m) => pathParams.push(m.slice(1, -1)));
}

const hasBody = ['POST', 'PUT', 'PATCH'].includes(method);
const queryRows = defaultQueryParams.length > 0
  ? defaultQueryParams
  : hideEmptyQueryRow
    ? []
    : [{ key: '', value: '' }];
const headerRows = defaultHeaders.length > 0
  ? defaultHeaders
  : [{ key: 'Content-Type', value: 'application/json' }];
---

<docsy-api-playground
  class="playground"
  data-method={method}
  data-endpoint={endpoint}
  data-base-url={baseUrl}
  data-proxy={proxy ? 'true' : 'false'}
>
  <!-- Header -->
  <div class="playground__header">
    <span class="playground__method" style={`background: ${methodColor};`}>
      {method}
    </span>
    <code class="playground__endpoint">{endpoint}</code>
  </div>

  {exampleLanguages.length > 0 && (
    <div class="playground__examples" aria-label="Example languages">
      <span class="playground__examples-label">Examples</span>
      <div class="playground__examples-list">
        {exampleLanguages.map((language) => (
          <span class="playground__examples-item">{language}</span>
        ))}
      </div>
    </div>
  )}

  <!-- Base URL input -->
  <div class="playground__section">
    <label class="playground__label" for="playground-base-url">Base URL</label>
    <input
      class="playground__input"
      id="playground-base-url"
      type="text"
      placeholder="https://api.example.com"
      value={baseUrl}
      data-field="baseUrl"
    />
  </div>

  <!-- Tabs for parameters -->
  <div class="playground__tabs" role="tablist">
    {pathParams.length > 0 && (
      <button
        class="playground__tab playground__tab--active"
        role="tab"
        aria-selected="true"
        data-tab="path"
      >
        Path
      </button>
    )}
    <button
      class:list={['playground__tab', { 'playground__tab--active': pathParams.length === 0 }]}
      role="tab"
      aria-selected={pathParams.length === 0 ? 'true' : 'false'}
      data-tab="query"
    >
      Query
    </button>
    <button
      class="playground__tab"
      role="tab"
      aria-selected="false"
      data-tab="headers"
    >
      Headers
    </button>
    {hasBody && (
      <button
        class="playground__tab"
        role="tab"
        aria-selected="false"
        data-tab="body"
      >
        Body
      </button>
    )}
  </div>

  <!-- Tab panels -->
  <div class="playground__panels">
    {/* Path parameters panel */}
    {pathParams.length > 0 && (
      <div class="playground__panel playground__panel--active" data-panel="path">
        {pathParams.map((param) => (
          <div class="playground__field">
            <label class="playground__field-label">
              <code class="playground__param-name">{param}</code>
              <span class="playground__param-badge">path</span>
            </label>
            <input
              class="playground__input"
              type="text"
              placeholder={`Value for ${param}`}
              data-path-param={param}
              value={defaultPathParams[param] || ''}
            />
          </div>
        ))}
      </div>
    )}

    {/* Query parameters panel */}
    <div
      class:list={['playground__panel', { 'playground__panel--active': pathParams.length === 0 }]}
      data-panel="query"
    >
      <div class="playground__kv-list" data-kv="query">
        {queryRows.map((row) => (
          <div class="playground__kv-row">
            <input class="playground__input playground__input--sm" type="text" placeholder="Key" data-kv-key value={row.key} />
            <input class="playground__input playground__input--sm" type="text" placeholder="Value" data-kv-value value={row.value} />
            <button class="playground__kv-remove" type="button" aria-label="Remove parameter" title="Remove">&times;</button>
          </div>
        ))}
      </div>
      <button class="playground__add-btn" type="button" data-add="query">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add parameter
      </button>
    </div>

    {/* Headers panel */}
    <div class="playground__panel" data-panel="headers">
      <div class="playground__kv-list" data-kv="headers">
        {headerRows.map((row) => (
          <div class="playground__kv-row">
            <input class="playground__input playground__input--sm" type="text" placeholder="Header name" data-kv-key value={row.key} />
            <input class="playground__input playground__input--sm" type="text" placeholder="Header value" data-kv-value value={row.value} />
            <button class="playground__kv-remove" type="button" aria-label="Remove header" title="Remove">&times;</button>
          </div>
        ))}
      </div>
      <button class="playground__add-btn" type="button" data-add="headers">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add header
      </button>
    </div>

    {/* Request body panel */}
    {hasBody && (
      <div class="playground__panel" data-panel="body">
        <textarea
          class="playground__textarea"
          data-field="body"
          placeholder='{ "key": "value" }'
          value={defaultBody}
          rows={8}
          spellcheck="false"
        />
      </div>
    )}
  </div>

  <!-- Send button -->
  <button class="playground__send" type="button" data-send>
    <svg class="playground__send-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="22" y1="2" x2="11" y2="13" />
      <polygon points="22 2 15 22 11 13 2 9 22 2" />
    </svg>
    <span class="playground__send-text">Send Request</span>
  </button>

  <!-- Response area (hidden until a response comes in) -->
  <div class="playground__response" data-response style="display:none;">
    <div class="playground__response-header">
      <span class="playground__response-title">Response</span>
      <span class="playground__status" data-status></span>
    </div>

    <!-- Response tabs -->
    <div class="playground__tabs playground__tabs--response" role="tablist">
      <button class="playground__tab playground__tab--active" role="tab" aria-selected="true" data-restab="body">Body</button>
      <button class="playground__tab" role="tab" aria-selected="false" data-restab="headers">Headers</button>
    </div>

    <div class="playground__response-panels">
      <div class="playground__response-panel playground__response-panel--active" data-respanel="body">
        <pre class="playground__response-body"><code data-response-body></code></pre>
      </div>
      <div class="playground__response-panel" data-respanel="headers">
        <pre class="playground__response-body"><code data-response-headers></code></pre>
      </div>
    </div>
  </div>

  <!-- Error display -->
  <div class="playground__error" data-error style="display:none;">
    <span class="playground__error-text" data-error-text></span>
  </div>
</docsy-api-playground>

<script>
  class DocsyApiPlayground extends HTMLElement {
    connectedCallback() {
      this.initTabs();
      this.initResponseTabs();
      this.initKvButtons();
      this.initSend();
    }

    /** Wire up the parameter tabs (Path / Query / Headers / Body) */
    initTabs() {
      const tabs = this.querySelectorAll<HTMLButtonElement>('.playground__tabs:not(.playground__tabs--response) [data-tab]');
      const panels = this.querySelectorAll<HTMLElement>('.playground__panels > [data-panel]');

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          tabs.forEach((t) => {
            t.classList.remove('playground__tab--active');
            t.setAttribute('aria-selected', 'false');
          });
          tab.classList.add('playground__tab--active');
          tab.setAttribute('aria-selected', 'true');

          const target = tab.dataset.tab;
          panels.forEach((p) => {
            p.classList.toggle('playground__panel--active', p.dataset.panel === target);
          });
        });
      });
    }

    /** Wire up the response tabs (Body / Headers) */
    initResponseTabs() {
      const tabs = this.querySelectorAll<HTMLButtonElement>('[data-restab]');
      const panels = this.querySelectorAll<HTMLElement>('[data-respanel]');

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          tabs.forEach((t) => {
            t.classList.remove('playground__tab--active');
            t.setAttribute('aria-selected', 'false');
          });
          tab.classList.add('playground__tab--active');
          tab.setAttribute('aria-selected', 'true');

          const target = tab.dataset.restab;
          panels.forEach((p) => {
            p.classList.toggle('playground__response-panel--active', p.dataset.respanel === target);
          });
        });
      });
    }

    /** Handle Add / Remove for key-value pair rows (query params, headers) */
    initKvButtons() {
      // Add buttons
      this.querySelectorAll<HTMLButtonElement>('[data-add]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const type = btn.dataset.add!;
          const list = this.querySelector(`[data-kv="${type}"]`);
          if (!list) return;

          const row = document.createElement('div');
          row.className = 'playground__kv-row';
          row.innerHTML = `
            <input class="playground__input playground__input--sm" type="text" placeholder="${type === 'headers' ? 'Header name' : 'Key'}" data-kv-key />
            <input class="playground__input playground__input--sm" type="text" placeholder="${type === 'headers' ? 'Header value' : 'Value'}" data-kv-value />
            <button class="playground__kv-remove" type="button" aria-label="Remove" title="Remove">&times;</button>
          `;
          list.appendChild(row);
          this.bindRemoveBtn(row.querySelector('.playground__kv-remove')!);
          // Focus the new key input
          row.querySelector<HTMLInputElement>('[data-kv-key]')?.focus();
        });
      });

      // Bind existing remove buttons
      this.querySelectorAll<HTMLButtonElement>('.playground__kv-remove').forEach((btn) => {
        this.bindRemoveBtn(btn);
      });
    }

    bindRemoveBtn(btn: Element) {
      btn.addEventListener('click', () => {
        const row = btn.closest('.playground__kv-row');
        const list = row?.parentElement;
        // Keep at least one row
        if (list && list.children.length > 1) {
          row?.remove();
        } else {
          // Clear the values instead of removing
          row?.querySelectorAll<HTMLInputElement>('input').forEach((input) => {
            input.value = '';
          });
        }
      });
    }

    /** Collect all form data and send the request */
    initSend() {
      const sendBtn = this.querySelector<HTMLButtonElement>('[data-send]');
      if (!sendBtn) return;

      sendBtn.addEventListener('click', () => this.sendRequest());
    }

    async sendRequest() {
      const method = this.dataset.method || 'GET';
      let endpoint = this.dataset.endpoint || '/';
      const sendBtn = this.querySelector<HTMLButtonElement>('[data-send]');
      const sendText = this.querySelector<HTMLElement>('.playground__send-text');
      const responseEl = this.querySelector<HTMLElement>('[data-response]');
      const errorEl = this.querySelector<HTMLElement>('[data-error]');

      // Get base URL
      const baseUrlInput = this.querySelector<HTMLInputElement>('[data-field="baseUrl"]');
      const baseUrl = (baseUrlInput?.value || this.dataset.baseUrl || '').replace(/\/+$/, '');
      const proxyEnabled = this.dataset.proxy === 'true';

      // Substitute path parameters
      this.querySelectorAll<HTMLInputElement>('[data-path-param]').forEach((input) => {
        const param = input.dataset.pathParam!;
        const val = input.value || `:${param}`;
        endpoint = endpoint.replace(`:${param}`, encodeURIComponent(val));
        endpoint = endpoint.replace(`{${param}}`, encodeURIComponent(val));
      });

      // Build query string
      const queryParts: string[] = [];
      const queryList = this.querySelector('[data-kv="query"]');
      if (queryList) {
        queryList.querySelectorAll('.playground__kv-row').forEach((row) => {
          const key = row.querySelector<HTMLInputElement>('[data-kv-key]')?.value?.trim();
          const val = row.querySelector<HTMLInputElement>('[data-kv-value]')?.value ?? '';
          if (key) {
            queryParts.push(`${encodeURIComponent(key)}=${encodeURIComponent(val)}`);
          }
        });
      }

      // Build headers
      const headers: Record<string, string> = {};
      const headersList = this.querySelector('[data-kv="headers"]');
      if (headersList) {
        headersList.querySelectorAll('.playground__kv-row').forEach((row) => {
          const key = row.querySelector<HTMLInputElement>('[data-kv-key]')?.value?.trim();
          const val = row.querySelector<HTMLInputElement>('[data-kv-value]')?.value ?? '';
          if (key) {
            headers[key] = val;
          }
        });
      }

      // Build body
      let body: string | undefined;
      if (['POST', 'PUT', 'PATCH'].includes(method)) {
        const bodyArea = this.querySelector<HTMLTextAreaElement>('[data-field="body"]');
        if (bodyArea?.value?.trim()) {
          body = bodyArea.value.trim();
        }
      }

      // Construct URL
      let url = proxyEnabled ? endpoint : `${baseUrl}${endpoint}`;
      if (queryParts.length > 0) {
        url += `?${queryParts.join('&')}`;
      }

      // Hide previous response/error
      if (responseEl) responseEl.style.display = 'none';
      if (errorEl) errorEl.style.display = 'none';

      // Update button to loading state
      if (sendBtn) sendBtn.disabled = true;
      if (sendText) sendText.textContent = 'Sending...';

      try {
        const fetchOptions: RequestInit = {
          method,
          headers,
        };
        if (body) {
          fetchOptions.body = body;
        }

        const response = await fetch(url, fetchOptions);

        // Read response
        const responseText = await response.text();

        // Try to format JSON
        let formattedBody: string;
        try {
          const parsed = JSON.parse(responseText);
          formattedBody = JSON.stringify(parsed, null, 2);
        } catch {
          formattedBody = responseText;
        }

        // Collect response headers
        const responseHeaders: string[] = [];
        response.headers.forEach((value, key) => {
          responseHeaders.push(`${key}: ${value}`);
        });

        // Status styling
        const statusEl = this.querySelector<HTMLElement>('[data-status]');
        if (statusEl) {
          statusEl.textContent = `${response.status} ${response.statusText}`;
          statusEl.className = 'playground__status';
          if (response.status >= 200 && response.status < 300) {
            statusEl.classList.add('playground__status--success');
          } else if (response.status >= 400) {
            statusEl.classList.add('playground__status--error');
          } else {
            statusEl.classList.add('playground__status--info');
          }
        }

        // Populate response body
        const bodyEl = this.querySelector<HTMLElement>('[data-response-body]');
        if (bodyEl) bodyEl.textContent = formattedBody || '(empty response)';

        // Populate response headers
        const headersEl = this.querySelector<HTMLElement>('[data-response-headers]');
        if (headersEl) headersEl.textContent = responseHeaders.join('\n') || '(no headers)';

        // Show response area and ensure body tab is active
        if (responseEl) responseEl.style.display = '';
        const bodyTabBtn = this.querySelector<HTMLButtonElement>('[data-restab="body"]');
        if (bodyTabBtn) bodyTabBtn.click();

      } catch (err: any) {
        if (errorEl) {
          const errorTextEl = errorEl.querySelector<HTMLElement>('[data-error-text]');
          if (errorTextEl) {
            errorTextEl.textContent = err?.message || 'An unknown error occurred';
          }
          errorEl.style.display = '';
        }
      } finally {
        if (sendBtn) sendBtn.disabled = false;
        if (sendText) sendText.textContent = 'Send Request';
      }
    }
  }

  if (!customElements.get('docsy-api-playground')) {
    customElements.define('docsy-api-playground', DocsyApiPlayground);
  }
</script>

<style>
  /* ================================================================
     API Playground Component
     Uses docsy CSS custom properties for theme integration.
     ================================================================ */

  .playground {
    display: block;
    border: 1px solid var(--docsy-border-color, #e5e7eb);
    border-radius: var(--docsy-radius-lg, 12px);
    background: var(--docsy-bg-primary, #ffffff);
    overflow: hidden;
  }

  /* ---- Header (method badge + endpoint) ---- */

  .playground__header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1rem;
    border-bottom: 1px solid var(--docsy-border-color, #e5e7eb);
    background: var(--docsy-bg-secondary, #f9fafb);
    flex-wrap: wrap;
  }

  .playground__method {
    display: inline-flex;
    align-items: center;
    padding: 0.1875rem 0.5rem;
    font-size: var(--docsy-font-size-xs, 0.6875rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #ffffff;
    border-radius: var(--docsy-radius-sm, 4px);
    font-family: var(--docsy-font-code, monospace);
    flex-shrink: 0;
  }

  .playground__endpoint {
    font-size: var(--docsy-font-size-sm, 0.8125rem);
    font-family: var(--docsy-font-code, monospace);
    color: var(--docsy-text-primary, #111827);
    word-break: break-all;
    line-height: 1.4;
  }

  /* ---- Sections & Labels ---- */

  .playground__section {
    padding: 0.75rem 1rem 0;
  }

  .playground__examples {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem 0;
    flex-wrap: wrap;
  }

  .playground__examples-label {
    font-size: var(--docsy-font-size-xs, 0.6875rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--docsy-text-muted, #9ca3af);
  }

  .playground__examples-list {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .playground__examples-item {
    font-size: var(--docsy-font-size-xs, 0.6875rem);
    font-weight: 500;
    color: var(--docsy-text-secondary, #6b7280);
    background: var(--docsy-bg-secondary, #f9fafb);
    border: 1px solid var(--docsy-border-color, #e5e7eb);
    border-radius: 999px;
    padding: 0.125rem 0.5rem;
    text-transform: lowercase;
  }

  .playground__label {
    display: block;
    font-size: var(--docsy-font-size-xs, 0.6875rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--docsy-text-muted, #9ca3af);
    margin-bottom: 0.375rem;
  }

  /* ---- Inputs ---- */

  .playground__input {
    display: block;
    width: 100%;
    padding: 0.5rem 0.75rem;
    font-size: var(--docsy-font-size-sm, 0.8125rem);
    font-family: var(--docsy-font-code, monospace);
    color: var(--docsy-text-primary, #111827);
    background: var(--docsy-bg-primary, #ffffff);
    border: 1px solid var(--docsy-border-color, #e5e7eb);
    border-radius: var(--docsy-radius-sm, 6px);
    outline: none;
    transition: border-color var(--docsy-transition-normal, 0.15s ease), box-shadow var(--docsy-transition-normal, 0.15s ease);
  }

  .playground__input::placeholder {
    color: var(--docsy-text-muted, #9ca3af);
  }

  .playground__input:focus {
    border-color: var(--docsy-color-primary, #6366f1);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
  }

  .playground__input--sm {
    padding: 0.375rem 0.625rem;
    font-size: var(--docsy-font-size-xs, 0.75rem);
  }

  /* ---- Textarea (JSON body editor) ---- */

  .playground__textarea {
    display: block;
    width: 100%;
    padding: 0.75rem;
    font-size: var(--docsy-font-size-sm, 0.8125rem);
    font-family: var(--docsy-font-code, monospace);
    line-height: 1.6;
    color: var(--docsy-text-primary, #111827);
    background: var(--docsy-bg-primary, #ffffff);
    border: 1px solid var(--docsy-border-color, #e5e7eb);
    border-radius: var(--docsy-radius-sm, 6px);
    outline: none;
    resize: vertical;
    min-height: 120px;
    transition: border-color var(--docsy-transition-normal, 0.15s ease), box-shadow var(--docsy-transition-normal, 0.15s ease);
  }

  .playground__textarea::placeholder {
    color: var(--docsy-text-muted, #9ca3af);
  }

  .playground__textarea:focus {
    border-color: var(--docsy-color-primary, #6366f1);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
  }

  /* ---- Tabs ---- */

  .playground__tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--docsy-border-color, #e5e7eb);
    padding: 0 1rem;
    margin-top: 0.5rem;
    overflow-x: auto;
  }

  .playground__tabs--response {
    margin-top: 0;
  }

  .playground__tab {
    padding: 0.5rem 0.75rem;
    border: none;
    background: none;
    font-size: var(--docsy-font-size-xs, 0.75rem);
