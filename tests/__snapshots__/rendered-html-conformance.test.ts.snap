exports[`Rendered HTML conformance snapshots > renders API playground runtime attributes from config + OpenAPI defaults > api-playground-markup 1`] = `"<docsy-api-playground class="playground" data-method="GET" data-endpoint="/users/{userId}" data-base-url="https://api.example.com" data-proxy-mode="enabled"> <!-- Header --> <div class="playground__header"> <span class="playground__method" style="background: #22c55e;"> GET </span> <code class="playground__endpoint">/users/{userId}</code> </div> <div class="playground__examples" aria-label="Example languages"> <span class="playground__examples-label">Examples</span> <div class="playground__examples-list"> <span class="playground__examples-item">curl</span><span class="playground__examples-item">python</span><span class="playground__examples-item">javascript</span><span class="playground__examples-item">go</span> </div> </div> <!-- Base URL input --> <div class="playground__section"> <label class="playground__label" for="playground-base-url">Base URL</label> <input class="playground__input" id="playground-base-url" type="text" placeholder="https://api.example.com" value="https://api.example.com" data-field="baseUrl"> </div> <!-- Tabs for parameters --> <div class="playground__tabs" role="tablist"> <button class="playground__tab playground__tab--active" role="tab" aria-selected="true" data-tab="path"> Path </button> <button class="playground__tab" role="tab" aria-selected="false" data-tab="query"> Query </button> <button class="playground__tab" role="tab" aria-selected="false" data-tab="headers"> Headers </button> </div> <!-- Tab panels --> <div class="playground__panels"> <div class="playground__panel playground__panel--active" data-panel="path"> <div class="playground__field"> <label class="playground__field-label"> <code class="playground__param-name">userId</code> <span class="playground__param-badge">path</span> </label> <input class="playground__input" type="text" placeholder="Value for userId" data-path-param="userId" value> </div> </div> <div class="playground__panel" data-panel="query"> <div class="playground__kv-list" data-kv="query"> <div class="playground__kv-row"> <input class="playground__input playground__input--sm" type="text" placeholder="Key" data-kv-key value> <input class="playground__input playground__input--sm" type="text" placeholder="Value" data-kv-value value> <button class="playground__kv-remove" type="button" aria-label="Remove parameter" title="Remove">&times;</button> </div> </div> <button class="playground__add-btn" type="button" data-add="query"> <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg> Add parameter </button> </div> <div class="playground__panel" data-panel="headers"> <div class="playground__kv-list" data-kv="headers"> <div class="playground__kv-row"> <input class="playground__input playground__input--sm" type="text" placeholder="Header name" data-kv-key value="Content-Type"> <input class="playground__input playground__input--sm" type="text" placeholder="Header value" data-kv-value value="application/json"> <button class="playground__kv-remove" type="button" aria-label="Remove header" title="Remove">&times;</button> </div> </div> <button class="playground__add-btn" type="button" data-add="headers"> <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg> Add header </button> </div> </div> <!-- Send button --> <button class="playground__send" type="button" data-send> <svg class="playground__send-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"> <line x1="22" y1="2" x2="11" y2="13"></line> <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon> </svg> <span class="playground__send-text">Send Request</span> </button> <!-- Response area (hidden until a response comes in) --> <div class="playground__response" data-response style="display:none;"> <div class="playground__response-header"> <span class="playground__response-title">Response</span> <span class="playground__status" data-status></span> </div> <!-- Response tabs --> <div class="playground__tabs playground__tabs--response" role="tablist"> <button class="playground__tab playground__tab--active" role="tab" aria-selected="true" data-restab="body">Body</button> <button class="playground__tab" role="tab" aria-selected="false" data-restab="headers">Headers</button> </div> <div class="playground__response-panels"> <div class="playground__response-panel playground__response-panel--active" data-respanel="body"> <pre class="playground__response-body"><code data-response-body></code></pre> </div> <div class="playground__response-panel" data-respanel="headers"> <pre class="playground__response-body"><code data-response-headers></code></pre> </div> </div> </div> <!-- Error display --> <div class="playground__error" data-error style="display:none;"> <span class="playground__error-text" data-error-text></span> </div> </docsy-api-playground>"`;

