exports[`Rendered HTML conformance snapshots > renders language-specific navigation in built i18n pages > i18n-es-topnav 1`] = `"<header class="topnav" id="topnav"> <div class="topnav-inner"> <div class="topnav-left"> <button class="topnav-mobile-toggle" id="mobile-menu-toggle" type="button" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu"> <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"> <line x1="3" y1="6" x2="21" y2="6"></line> <line x1="3" y1="12" x2="21" y2="12"></line> <line x1="3" y1="18" x2="21" y2="18"></line> </svg> </button> <a href="/" class="topnav-logo"> <span class="topnav-site-name">I18n Fixture</span> </a> </div> <div class="topnav-center"> <div class="topnav-search" id="search-bar"> <button class="search-trigger" type="button" aria-label="Search documentation"> <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"> <circle cx="7" cy="7" r="4.5"></circle> <path d="M10.5 10.5L14 14"></path> </svg> <span class="search-placeholder">Search docs...</span> <kbd class="search-kbd"> <span class="search-kbd-meta">/</span> </kbd> </button> </div> </div> <div class="topnav-right"> <div class="lang-switcher" id="lang-switcher"><button class="lang-switcher-trigger" type="button" aria-expanded="false" aria-haspopup="true"><svg class="lang-switcher-globe" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="6.5"></circle><path d="M1.5 8h13"></path><path d="M8 1.5c1.5 2 2.5 4 2.5 6.5s-1 4.5-2.5 6.5"></path><path d="M8 1.5c-1.5 2-2.5 4-2.5 6.5s1 4.5 2.5 6.5"></path></svg><span class="lang-switcher-label">Español</span><svg class="lang-switcher-chevron" width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></button><div class="lang-switcher-dropdown" id="lang-dropdown" role="menu"><a href="/introduccion" class="lang-switcher-option" role="menuitem">English</a><a href="/es/introduccion" class="lang-switcher-option active" role="menuitem" aria-current="true">Español</a></div></div><script type="module">function a(){const n=document.getElementById("lang-switcher");if(!n)return;const t=n.querySelector(".lang-switcher-trigger"),r=document.getElementById("lang-dropdown");if(!t||!r)return;function o(){const e=t.getAttribute("aria-expanded")==="true";t.setAttribute("aria-expanded",String(!e)),r.classList.toggle("open",!e)}function i(){t.setAttribute("aria-expanded","false"),r.classList.remove("open")}t.addEventListener("click",e=>{e.stopPropagation(),o()}),document.addEventListener("click",e=>{n.contains(e.target)||i()}),document.addEventListener("keydown",e=>{e.key==="Escape"&&i()})}a();document.addEventListener("astro:after-swap",a);</script> <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle color theme" title="Toggle color theme"><svg class="theme-icon theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg><svg class="theme-icon theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path></svg></button><script type="module">function c(){const n=document.getElementById("theme-toggle");if(!n)return;function a(){const e=localStorage.getItem("docsy-theme");return e||(window.matchMedia("(prefers-color-scheme: dark)").matches?"dark":"light")}function r(e){document.documentElement.setAttribute("data-theme",e),localStorage.setItem("docsy-theme",e),o(e)}function o(e){n.setAttribute("aria-label",e==="dark"?"Switch to light theme":"Switch to dark theme")}o(a()),n.addEventListener("click",()=>{const t=(document.documentElement.getAttribute("data-theme")||a())==="dark"?"light":"dark";r(t)}),window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change",e=>{if(!localStorage.getItem("docsy-theme")){const t=e.matches?"dark":"light";document.documentElement.setAttribute("data-theme",t),o(t)}})}c();document.addEventListener("astro:after-swap",c);</script> </div> </div> </header>"`;

