{
  "name": "docsy",
  "version": "0.1.0",
  "description": "Open-source documentation framework built on Astro. A Mintlify alternative.",
  "type": "module",
  "bin": {
    "docsy": "./dist/cli/index.mjs"
  },
  "exports": {
    ".": "./dist/integration/index.mjs",
    "./components": "./src/template/src/components/mdx/index.ts"
  },
  "files": [
    "dist/",
    "src/template/",
    "src/init-template/",
    "src/lib/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli/index.mjs",
    "test": "vitest"
  },
  "keywords": [
    "documentation",
    "docs",
    "astro",
    "mdx",
    "mintlify",
    "static-site-generator"
  ],
  "license": "MIT",
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@astrojs/mdx": "^4.2.0",
    "@astrojs/react": "^4.2.0",
    "@astrojs/sitemap": "^3.3.0",
    "@astrojs/vercel": "^8.1.0",
    "astro": "^5.6.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.0",
    "gray-matter": "^4.0.3",
    "ora": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
